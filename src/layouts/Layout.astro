---
import '../styles/global.css';
import DarkModeToggle from '../components/DarkModeToggle.astro';
import MobileMenu from '../components/MobileMenu.astro';
import SearchModal from '../components/SearchModal.astro';
import LangSwitcher from '../components/LangSwitcher.astro';
import MarketTicker from '../components/MarketTicker.astro';
import { CHROME, HREFLANG, LOCALE_LIST, RTL_LOCALES, type Locale } from '../i18n/tool-strings';

function resolveLocale(raw: string): Locale {
  if ((LOCALE_LIST as string[]).includes(raw)) return raw as Locale;
  // Handle hreflang forms like "pt-BR" → "pt"
  const base = raw.split('-')[0];
  for (const l of LOCALE_LIST) {
    if (l === raw || l.split('-')[0] === base) return l;
  }
  return 'en';
}

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageWidth?: number;
  imageHeight?: number;
  url?: string;
  type?: string;
  schema?: string;
  publishDate?: Date;
  modifiedDate?: Date;
  authorName?: string;
  tags?: string[];
  section?: string;
  lang?: string;
  hreflangAlternates?: Array<{ hreflang: string; href: string }>;
  ampUrl?: string;
}

const {
  title,
  description = 'In-depth tech news, analysis, and expert commentary on the stories shaping the industry.',
  image = '/favicon.svg',
  imageWidth,
  imageHeight,
  url = Astro.url.href,
  type = 'website',
  schema,
  publishDate,
  modifiedDate,
  authorName = 'System Report Staff',
  tags = [],
  section,
  lang = 'en',
  hreflangAlternates = [],
  ampUrl,
} = Astro.props;

const canonicalUrl = new URL(url, Astro.site);
const currentYear = new Date().getFullYear();

// OG spec requires absolute URLs for og:image
const absoluteImage = image.startsWith('http') ? image : new URL(image, Astro.site || 'https://www.systemreport.net').href;

// Resolve locale + derive chrome strings. Derive the URL prefix from the
// current pathname so Home/Tools links always match the deployed casing
// (e.g. /zh-CN/ for posts, /zh-cn/ for tools — both exist in this repo).
const locale = resolveLocale(lang);
const t = CHROME[locale];
const htmlLang = HREFLANG[locale];
const isRtl = RTL_LOCALES.has(locale);
const firstSeg = Astro.url.pathname.split('/').filter(Boolean)[0] || '';
const localeSlugs = new Set<string>(LOCALE_LIST.map((l) => l.toLowerCase()).concat(LOCALE_LIST));
const isLocalized = localeSlugs.has(firstSeg);
const localePrefix = isLocalized ? `/${firstSeg}` : '';
const homeHref = `${localePrefix}/`;
const toolsHref = `${localePrefix}/tools`;
---

<!doctype html>
<html lang={htmlLang} dir={isRtl ? 'rtl' : 'ltr'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />
    {ampUrl && <link rel="amphtml" href={ampUrl} />}

    {hreflangAlternates.map(({ hreflang, href }) => (
      <link rel="alternate" hreflang={hreflang} href={href} />
    ))}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteImage} />
    {imageWidth && <meta property="og:image:width" content={String(imageWidth)} />}
    {imageHeight && <meta property="og:image:height" content={String(imageHeight)} />}
    {absoluteImage && !absoluteImage.endsWith('.svg') && <meta property="og:image:type" content="image/jpeg" />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="System Report" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />

    {type === 'article' && publishDate && <meta property="article:published_time" content={publishDate.toISOString()} />}
    {type === 'article' && modifiedDate && <meta property="article:modified_time" content={modifiedDate.toISOString()} />}
    {type === 'article' && !modifiedDate && publishDate && <meta property="article:modified_time" content={publishDate.toISOString()} />}
    {type === 'article' && <meta property="article:author" content={authorName} />}
    {type === 'article' && section && <meta property="article:section" content={section} />}
    {type === 'article' && tags.map((tag) => <meta property="article:tag" content={tag} />)}
    
    {schema && <script type="application/ld+json" set:html={schema} />}

    <!-- RSS Discovery -->
    <link rel="alternate" type="application/rss+xml" title="System Report" href="/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title="System Report — Narrated (Podcast)" href="/podcast.xml" />
    <link rel="alternate" type="application/feed+json" title="System Report (JSON Feed)" href="/feed.json" />

    <!-- Webmaster verification (env-gated; set at build time) -->
    {import.meta.env.BING_SITE_VERIFICATION && (
      <meta name="msvalidate.01" content={import.meta.env.BING_SITE_VERIFICATION} />
    )}
    {import.meta.env.GOOGLE_SITE_VERIFICATION && (
      <meta name="google-site-verification" content={import.meta.env.GOOGLE_SITE_VERIFICATION} />
    )}
    {import.meta.env.YANDEX_VERIFICATION && (
      <meta name="yandex-verification" content={import.meta.env.YANDEX_VERIFICATION} />
    )}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Theme color (Best Practices) -->
    <meta name="theme-color" content="#fafaf8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />

    <!-- Dark mode: prevent FOUC -->
    <script is:inline>
      (function() {
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <!-- Google Funding Choices — serves GDPR/CCPA consent banners configured in AdSense Privacy & messaging -->
    <script async src="https://fundingchoicesmessages.google.com/i/pub-4803415346052918?ers=1"></script>
    <script>window.googlefc = window.googlefc || {}; window.googlefc.callbackQueue = window.googlefc.callbackQueue || [];</script>

    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4803415346052918" crossorigin="anonymous"></script>

    <meta name="generator" content={Astro.generator} />
  </head>

  <body class="bg-[#fafaf8] dark:bg-black text-gray-900 dark:text-gray-100 font-sans antialiased min-h-screen flex flex-col">

    <!-- Header -->
    <header class="sticky top-0 z-40 bg-white dark:bg-black border-b border-gray-200 dark:border-gray-800">
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-14">
          <!-- Logo -->
          <a href="/" class="flex items-center hover:opacity-80 transition-opacity" id="site-logo" aria-label="System Report">
            <img src="/logo-light.png" alt="System Report" class="h-5 sm:h-6 w-auto block dark:hidden" width="1200" height="124" fetchpriority="high" decoding="async" />
            <img src="/logo-dark.png"  alt="System Report" class="h-5 sm:h-6 w-auto hidden dark:block" width="1200" height="124" fetchpriority="high" decoding="async" />
          </a>

          <!-- Desktop Nav -->
          <nav class="hidden md:flex items-center gap-1">
            <a href={homeHref} class="px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-black dark:hover:text-white rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
              {t.home}
            </a>
            <a href="/tech" class="px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-black dark:hover:text-white rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
              {t.tech}
            </a>
            <a href="/gaming" class="px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-black dark:hover:text-white rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
              {t.gaming}
            </a>
            <a href="/ai" class="px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-black dark:hover:text-white rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
              {t.ai}
            </a>
            <a href="/software" class="px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-black dark:hover:text-white rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
              {t.software}
            </a>
            <a href="/hardware" class="px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-black dark:hover:text-white rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
              {t.hardware}
            </a>
            <a href={toolsHref} class="px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-black dark:hover:text-white rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
              {t.tools}
            </a>

            <div class="w-px h-5 bg-gray-200 dark:bg-gray-700 mx-2"></div>

            <!-- Search button -->
            <button
              id="search-trigger"
              class="flex items-center gap-2 px-3 py-1.5 text-sm text-gray-400 dark:text-gray-500 bg-gray-100 dark:bg-gray-800 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
              type="button"
              aria-label={t.search}
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
              </svg>
              <span class="hidden lg:inline">{t.search}</span>
              <kbd class="hidden lg:inline-flex items-center px-1.5 py-0.5 bg-white dark:bg-gray-900 rounded text-[10px] text-gray-400 dark:text-gray-500 font-mono border border-gray-200 dark:border-gray-700">⌘K</kbd>
            </button>

            <LangSwitcher hreflangAlternates={hreflangAlternates} currentLang={lang} />
            <DarkModeToggle />
          </nav>

          <!-- Mobile: search + dark mode + hamburger -->
          <div class="flex md:hidden items-center gap-1">
            <button
              id="search-trigger-mobile"
              class="p-2 rounded-lg text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
              type="button"
              aria-label={t.search}
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
              </svg>
            </button>

            <DarkModeToggle />

            <button
              id="mobile-menu-trigger"
              class="p-2 rounded-lg text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
              type="button"
              aria-label={t.openMenu}
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </header>

    <MarketTicker />

    <MobileMenu lang={locale} />
    <SearchModal />

    <!-- Main content -->
    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full" data-pagefind-body>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-black mt-auto" data-pagefind-ignore="all">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Brand -->
          <div>
            <img src="/logo-light.png" alt="System Report" class="h-6 w-auto block dark:hidden" width="1200" height="124" />
            <img src="/logo-dark.png"  alt="System Report" class="h-6 w-auto hidden dark:block" width="1200" height="124" />
            <p class="mt-3 text-sm text-gray-500 dark:text-gray-400 leading-relaxed max-w-xs">
              {t.brandTagline}
            </p>
          </div>

          <!-- Navigate -->
          <div>
            <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 uppercase tracking-wider mb-4">{t.navigateHeading}</h3>
            <ul class="space-y-2.5">
              <li><a href={homeHref} class="text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">{t.home}</a></li>
              <li><a href="/tech" class="text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">{t.tech}</a></li>
              <li><a href="/gaming" class="text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">{t.gaming}</a></li>
              <li><a href="/ai" class="text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">{t.ai}</a></li>
              <li><a href="/software" class="text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">{t.software}</a></li>
              <li><a href="/hardware" class="text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">{t.hardware}</a></li>
              <li><a href={toolsHref} class="text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">{t.tools}</a></li>
              <li><a href="/tags" class="text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">{t.tags}</a></li>
              <li><a href="/authors" class="text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">{t.team}</a></li>
              <li><a href={`${localePrefix}/about`} class="text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">{t.about}</a></li>
              <li><a href={`${localePrefix}/contact`} class="text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">{t.contact}</a></li>
              <li><a href={`${localePrefix}/privacy`} class="text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">{t.privacy}</a></li>
              <li><a href={`${localePrefix}/terms`} class="text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">{t.terms}</a></li>
            </ul>
          </div>

          <!-- Subscribe -->
          <div>
            <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 uppercase tracking-wider mb-4">{t.stayUpdatedHeading}</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">{t.followFeed}</p>
            <a
              href="/rss.xml"
              class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-lg text-sm font-medium hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12.75 19.5v-.75a7.5 7.5 0 0 0-7.5-7.5H4.5m0-6.75h.75c7.87 0 14.25 6.38 14.25 14.25v.75M6 18.75a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
              </svg>
              {t.rssFeed}
            </a>
          </div>
        </div>

        <div class="border-t border-gray-100 dark:border-gray-800 mt-10 pt-8">
          <p class="text-sm text-gray-500 dark:text-gray-400">
            &copy; {currentYear} System Report. {t.copyright}
          </p>
        </div>
      </div>
    </footer>

    <!-- WebMCP: Expose site tools to AI agents via browser -->
    <script is:inline>
      (function() {
        if (typeof navigator === 'undefined' || !navigator.modelContext) return;
        try {
          navigator.modelContext.registerTool({
            name: 'search-articles',
            description: 'Search System Report tech news articles by keyword. Returns matching articles with title, URL, date, tags, and description.',
            inputSchema: {
              type: 'object',
              properties: {
                query: { type: 'string', description: 'Search term or phrase' }
              },
              required: ['query']
            },
            execute: async function(params) {
              var r = await fetch('/data/posts.json');
              var data = await r.json();
              var q = (params.query || '').toLowerCase();
              var matches = data.items.filter(function(item) {
                return item.title.toLowerCase().includes(q) ||
                       (item.description || '').toLowerCase().includes(q) ||
                       (item.tags || []).some(function(t) { return t.toLowerCase().includes(q); });
              }).slice(0, 10);
              return JSON.stringify(matches);
            }
          });
          navigator.modelContext.registerTool({
            name: 'get-latest-articles',
            description: 'Get the most recently published tech news articles from System Report with full metadata.',
            inputSchema: {
              type: 'object',
              properties: {
                limit: { type: 'integer', description: 'Number of articles to return (default 10)', default: 10 }
              }
            },
            execute: async function(params) {
              var r = await fetch('/data/posts.json');
              var data = await r.json();
              var limit = params.limit || 10;
              return JSON.stringify(data.items.slice(0, limit));
            }
          });
          navigator.modelContext.registerTool({
            name: 'navigate-to-section',
            description: 'Navigate to a section of System Report. Available sections: home, tech, ai, gaming, software, hardware, tools, about, contact, privacy.',
            inputSchema: {
              type: 'object',
              properties: {
                section: { type: 'string', description: 'Section name to navigate to' }
              },
              required: ['section']
            },
            execute: function(params) {
              var routes = {
                home: '/', tech: '/tech', ai: '/ai', gaming: '/gaming',
                software: '/software', hardware: '/hardware', tools: '/tools',
                about: '/about', contact: '/contact', privacy: '/privacy',
                'exif-stripper': '/tools/exif-stripper/', tags: '/tags'
              };
              var path = routes[(params.section || '').toLowerCase()] || '/';
              window.location.href = path;
              return JSON.stringify({ navigated: path });
            }
          });
        } catch(e) { /* WebMCP not supported */ }
      })();
    </script>

    <!-- Mobile search trigger script -->
    <script>
      document.getElementById('search-trigger-mobile')?.addEventListener('click', () => {
        document.getElementById('search-trigger')?.click();
      });
    </script>
  </body>
</html>
