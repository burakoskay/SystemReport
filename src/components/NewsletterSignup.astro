---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<section class:list={[
  'rounded-2xl border',
  compact
    ? 'p-6 bg-gray-50 dark:bg-gray-900 border-gray-200 dark:border-gray-800'
    : 'p-8 md:p-12 bg-gray-50 dark:bg-gray-900 border-gray-200 dark:border-gray-800'
]}>
  <div class={compact ? '' : 'max-w-2xl mx-auto text-center'}>
    <h3 class:list={[
      'font-serif font-bold text-gray-900 dark:text-gray-100',
      compact ? 'text-lg' : 'text-2xl md:text-3xl'
    ]}>
      {compact ? 'Stay in the loop' : 'Never miss a signal'}
    </h3>
    <p class:list={[
      'text-gray-500 dark:text-gray-400',
      compact ? 'mt-1 text-sm' : 'mt-3 text-base'
    ]}>
      {compact
        ? 'Get the latest tech news delivered.'
        : 'The latest tech news and analysis delivered straight to your inbox. No spam, unsubscribe anytime.'}
    </p>

    <form
      id="newsletter-form"
      class:list={[
        'flex gap-2',
        compact ? 'mt-4 flex-col sm:flex-row' : 'mt-6 flex-col sm:flex-row sm:max-w-md sm:mx-auto'
      ]}
      action="#"
      method="POST"
    >
      <input
        type="email"
        name="email"
        required
        autocomplete="email"
        placeholder="you@example.com"
        class="flex-1 px-4 py-2.5 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-xl text-sm text-gray-900 dark:text-gray-100 placeholder:text-gray-400 dark:placeholder:text-gray-500 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition-shadow"
        id="newsletter-email"
      />
      <button
        type="submit"
        class="px-5 py-2.5 bg-gray-900 hover:bg-black dark:bg-white dark:hover:bg-gray-100 text-white dark:text-gray-900 text-sm font-medium rounded-xl transition-colors whitespace-nowrap focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2 dark:focus:ring-offset-gray-900"
        id="newsletter-submit"
      >
        Subscribe
      </button>
    </form>

    <p class:list={[
      'text-gray-500 dark:text-gray-400',
      compact ? 'mt-2 text-xs' : 'mt-3 text-xs'
    ]}>
      Also available via <a href="/rss.xml" class="underline hover:text-gray-600 dark:hover:text-gray-300">RSS feed</a>
    </p>
  </div>
</section>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const submitBtn = document.getElementById('newsletter-submit');
  const emailInput = document.getElementById('newsletter-email') as HTMLInputElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!emailInput?.value) return;

    if (submitBtn) {
      submitBtn.textContent = 'Subscribing...';
      (submitBtn as HTMLButtonElement).disabled = true;
    }

    try {
      const response = await fetch('/api/newsletter', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ email: emailInput.value }),
      });

      if (!response.ok) {
        throw new Error('Subscription failed');
      }

      if (submitBtn) {
        submitBtn.textContent = '✓ Subscribed!';
        submitBtn.classList.remove('bg-gray-900', 'hover:bg-black', 'dark:bg-white', 'dark:hover:bg-gray-100');
        submitBtn.classList.add('bg-green-600', 'cursor-not-allowed');
      }

      if (emailInput) {
        emailInput.value = '';
      }
    } catch (error) {
      console.error('Newsletter subscription error:', error);
      if (submitBtn) {
        submitBtn.textContent = 'Error. Try again';
        (submitBtn as HTMLButtonElement).disabled = false;
      }
    }
  });
</script>
