---
interface Props {
  title: string;
  slug: string;
  date: Date;
  heroImage?: string;
  tags?: string[];
  description?: string;
  body?: string;
}

const { title, slug, date, heroImage, tags = [], description, body = '' } = Astro.props;

const words = (body || '').split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(words / 200));

const formattedDate = `${date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
})} · ${date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true, timeZone: 'UTC' })} UTC`;

const excerpt = description || (body ? body.slice(0, 140).replace(/[#*_\[\]`>]/g, '').trim() + '…' : '');
const category = tags[0] ?? null;
---

<article class="group bg-white dark:bg-gray-900/60 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden hover:border-gray-300 dark:hover:border-gray-700 transition-colors duration-200 animate-fade-in">
  {heroImage && (
    <a href={`/posts/${slug}`} class="block overflow-hidden aspect-video bg-gray-100 dark:bg-gray-800">
      <img
        src={heroImage}
        alt={title}
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    </a>
  )}

  <div class="p-5">
    {category && (
      <span class="text-[0.65rem] font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">
        {category}
      </span>
    )}

    <a href={`/posts/${slug}`} class="block mt-1.5">
      <h2 class="font-serif text-lg font-semibold leading-snug text-gray-900 dark:text-gray-100 group-hover:text-black dark:group-hover:text-white transition-colors line-clamp-2">
        {title}
      </h2>
    </a>

    {excerpt && (
      <p class="mt-2 text-sm text-gray-500 dark:text-gray-400 line-clamp-2 leading-relaxed">
        {excerpt}
      </p>
    )}

    <div class="flex items-center gap-3 mt-4 text-xs text-gray-500 dark:text-gray-400">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      <span class="w-1 h-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
      <span>{readingTime} min read</span>
    </div>
  </div>
</article>
