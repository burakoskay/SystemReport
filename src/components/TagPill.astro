---
interface Props {
  tag: string;
  size?: 'sm' | 'md';
  linked?: boolean;
}

const { tag, size = 'sm', linked = true } = Astro.props;

const sizeClasses = size === 'sm'
  ? 'px-2.5 py-0.5 text-xs'
  : 'px-3 py-1 text-sm';

const baseClasses = `inline-flex items-center rounded-full font-medium transition-colors duration-200 ${sizeClasses}`;
const colorClasses = 'bg-gray-100 text-gray-700 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700';
---

{linked ? (
  <a
    href={`/tags/${tag}`}
    class:list={[baseClasses, colorClasses]}
  >
    {tag}
  </a>
) : (
  <span class:list={[baseClasses, colorClasses]}>
    {tag}
  </span>
)}
