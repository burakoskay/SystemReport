---
// Side-scrolling live market ticker. Crypto via Binance, indices/FX via
// Stooq, FX rates via Frankfurter — all fanned out through /api/markets.
// The leading pill is a custom currency dropdown: the closed state shows
// only the selected symbol (auto-narrow), the open panel shows full names.
// The scrolling track is driven by requestAnimationFrame so the user can
// drag and "throw" it; a release velocity is carried forward with friction
// and decays back into the idle auto-scroll.
const SEED = [
  { sym: 'BTC',   label: 'BTC',     denom: 'USD'   },
  { sym: 'ETH',   label: 'ETH',     denom: 'USD'   },
  { sym: 'SOL',   label: 'SOL',     denom: 'USD'   },
  { sym: 'XRP',   label: 'XRP',     denom: 'USD'   },
  { sym: 'DOGE',  label: 'DOGE',    denom: 'USD'   },
  { sym: '^SPX',  label: 'S&P 500', denom: 'index' },
  { sym: '^NDX',  label: 'NASDAQ',  denom: 'index' },
  { sym: '^DJI',  label: 'DOW',     denom: 'index' },
  { sym: 'EURUSD',label: 'EUR/USD', denom: 'pair'  },
  { sym: 'USDJPY',label: 'USD/JPY', denom: 'pair'  },
  { sym: 'XAUUSD',label: 'GOLD',    denom: 'USD'   },
];

const CURRENCIES = [
  { code: 'USD', symbol: '$',    name: 'US Dollar' },
  { code: 'EUR', symbol: '€',    name: 'Euro' },
  { code: 'GBP', symbol: '£',    name: 'British Pound' },
  { code: 'JPY', symbol: '¥',    name: 'Japanese Yen' },
  { code: 'CHF', symbol: 'Fr',   name: 'Swiss Franc' },
  { code: 'CAD', symbol: 'C$',   name: 'Canadian Dollar' },
  { code: 'AUD', symbol: 'A$',   name: 'Australian Dollar' },
  { code: 'CNY', symbol: '¥',    name: 'Chinese Yuan' },
  { code: 'INR', symbol: '₹',    name: 'Indian Rupee' },
  { code: 'TRY', symbol: '₺',    name: 'Turkish Lira' },
  { code: 'MXN', symbol: 'Mex$', name: 'Mexican Peso' },
  { code: 'BRL', symbol: 'R$',   name: 'Brazilian Real' },
];
---

<div class="market-ticker border-b border-gray-200 dark:border-gray-800 bg-white dark:bg-black relative">
  <div class="flex items-stretch">

    <div class="shrink-0 relative z-20" data-currency-root>
      <button
        type="button"
        data-currency-btn
        class="h-full flex items-center gap-2 pl-3 pr-2 py-1.5 bg-gray-900 dark:bg-white text-white dark:text-black hover:opacity-90 transition-opacity"
        aria-haspopup="listbox"
        aria-expanded="false"
        aria-label="Display currency"
      >
        <span class="relative flex w-1.5 h-1.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-red-500"></span>
        </span>
        <span data-currency-symbol class="text-[11px] font-bold tracking-wide">$</span>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
        </svg>
      </button>
      <div
        data-currency-menu
        role="listbox"
        class="hidden absolute top-full left-0 mt-0 min-w-[12rem] max-h-80 overflow-auto bg-white dark:bg-black border border-gray-200 dark:border-gray-800 shadow-lg rounded-b-md"
      >
        {CURRENCIES.map((c) => (
          <button
            type="button"
            role="option"
            data-opt
            data-code={c.code}
            data-symbol={c.symbol}
            class="w-full flex items-center gap-3 px-3 py-2 text-[11px] text-left text-gray-900 dark:text-gray-100 hover:bg-gray-100 dark:hover:bg-gray-900 transition-colors"
          >
            <span class="w-8 font-bold tabular-nums">{c.symbol}</span>
            <span class="font-semibold">{c.code}</span>
            <span class="text-gray-500 dark:text-gray-400">{c.name}</span>
          </button>
        ))}
      </div>
    </div>

    <div class="market-ticker-viewport flex-1 overflow-hidden relative select-none">
      <div class="market-ticker-track flex items-center gap-8 py-1.5 whitespace-nowrap will-change-transform cursor-grab active:cursor-grabbing" data-ticker-track>
        {[0, 1].map(() => (
          <div class="flex items-center gap-8 pl-8 shrink-0" data-ticker-group>
            {SEED.map((item) => (
              <span class="flex items-center gap-2 text-xs tabular-nums" data-ticker-item data-sym={item.sym} data-denom={item.denom}>
                <span class="font-semibold text-gray-900 dark:text-gray-100">{item.label}</span>
                <span class="text-gray-700 dark:text-gray-300" data-v>—</span>
                <span class="text-gray-500 dark:text-gray-500" data-c>—</span>
              </span>
            ))}
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    // ── Currency dropdown ───────────────────────────────────────────────
    const STORAGE_KEY = 'sr-ticker-currency';
    const root    = document.querySelector('[data-currency-root]');
    const btn     = root && root.querySelector('[data-currency-btn]');
    const menu    = root && root.querySelector('[data-currency-menu]');
    const symEl   = root && root.querySelector('[data-currency-symbol]');
    const options = root ? [...root.querySelectorAll('[data-opt]')] : [];

    const state = {
      currency: (function () {
        try { return localStorage.getItem(STORAGE_KEY) || 'USD'; } catch { return 'USD'; }
      })(),
      items: {},
      rates: { USD: 1 },
    };

    const applyCurrency = (code, symbol) => {
      state.currency = code;
      if (symEl && symbol) symEl.textContent = symbol;
      try { localStorage.setItem(STORAGE_KEY, code); } catch {}
      render();
    };

    // Seed the pill with the persisted choice's symbol.
    {
      const picked = options.find(o => o.getAttribute('data-code') === state.currency);
      if (picked && symEl) symEl.textContent = picked.getAttribute('data-symbol');
    }

    const closeMenu = () => {
      if (!menu) return;
      menu.classList.add('hidden');
      btn && btn.setAttribute('aria-expanded', 'false');
    };
    const openMenu = () => {
      if (!menu) return;
      menu.classList.remove('hidden');
      btn && btn.setAttribute('aria-expanded', 'true');
    };

    if (btn) btn.addEventListener('click', (e) => {
      e.stopPropagation();
      if (menu && menu.classList.contains('hidden')) openMenu(); else closeMenu();
    });
    options.forEach((opt) => {
      opt.addEventListener('click', () => {
        applyCurrency(opt.getAttribute('data-code'), opt.getAttribute('data-symbol'));
        closeMenu();
      });
    });
    document.addEventListener('click', (e) => {
      if (root && !root.contains(e.target)) closeMenu();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });

    // ── Formatting / rendering ──────────────────────────────────────────
    const fmtNumber = (n, currency, denom) => {
      if (!isFinite(n)) return '—';
      if (denom === 'index') return n.toLocaleString('en-US', { maximumFractionDigits: 0 });
      if (denom === 'pair') {
        if (Math.abs(n) >= 10) return n.toLocaleString('en-US', { maximumFractionDigits: 2 });
        return n.toLocaleString('en-US', { minimumFractionDigits: 4, maximumFractionDigits: 4 });
      }
      const abs = Math.abs(n);
      const digits = abs >= 1000 ? 0 : abs >= 1 ? 2 : 4;
      try {
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency,
          minimumFractionDigits: digits,
          maximumFractionDigits: digits,
        }).format(n);
      } catch {
        return n.toLocaleString('en-US', { maximumFractionDigits: digits });
      }
    };
    const pct = (n) => isFinite(n) ? (n >= 0 ? '+' : '') + n.toFixed(2) + '%' : '—';

    function render() {
      const { currency, items, rates } = state;
      const fx = rates[currency];
      document.querySelectorAll('[data-ticker-item]').forEach((el) => {
        const sym   = el.getAttribute('data-sym');
        const denom = el.getAttribute('data-denom');
        const d = items[sym];
        const vE = el.querySelector('[data-v]');
        const cE = el.querySelector('[data-c]');
        if (!d || !isFinite(d.v)) return;
        const displayVal = denom === 'USD' && isFinite(fx) ? d.v * fx : d.v;
        if (vE) vE.textContent = fmtNumber(displayVal, currency, denom);
        if (cE && isFinite(d.c)) {
          cE.textContent = pct(d.c);
          cE.classList.remove('text-gray-500', 'dark:text-gray-500', 'text-green-600', 'dark:text-green-400', 'text-red-600', 'dark:text-red-400');
          cE.classList.add(d.c >= 0 ? 'text-green-600' : 'text-red-600', d.c >= 0 ? 'dark:text-green-400' : 'dark:text-red-400');
        }
      });
    }

    async function refresh() {
      try {
        const r = await fetch('/api/markets', { cache: 'no-store' });
        if (!r.ok) return;
        const data = await r.json();
        if (data.items) state.items = data.items;
        if (data.rates) state.rates = { USD: 1, ...data.rates };
        render();
      } catch (_) {}
    }
    refresh();
    setInterval(refresh, 60000);

    // ── Drag-to-throw marquee ───────────────────────────────────────────
    // CSS-keyframe marquee can't be interactively paused/resumed mid-flight,
    // so we drive translateX ourselves. The track contains two identical
    // groups side-by-side; wrapping at -halfWidth keeps the scroll seamless.
    const viewport = document.querySelector('.market-ticker-viewport');
    const track    = document.querySelector('[data-ticker-track]');
    const groups   = document.querySelectorAll('[data-ticker-group]');
    const prefersReduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (viewport && track && groups.length >= 2 && !prefersReduced) {
      // Old CSS marquee took 90s to traverse halfWidth. We preserve that
      // cadence so the scroll feels unchanged.
      const DURATION_S = 90;
      const FRICTION   = 2.2;        // exponential decay per second
      const MAX_VEL    = 4000;       // px/s clamp on released velocity
      const RESUME_MS  = 1200;       // after drag ends, delay before auto-drift takes over

      let x = 0;
      let halfWidth = 0;
      let autoSpeed = -15;           // px/s, recomputed after measure()
      let vel = 0;                   // carries through drag momentum
      let dragging = false;
      let paused = false;            // hover-pause
      let releasedAt = 0;
      let samples = [];              // [t, x] recent pointer positions
      let lastFrame = 0;

      const measure = () => {
        halfWidth = groups[0].getBoundingClientRect().width + 32; /* pl-8 gap */
        autoSpeed = -halfWidth / DURATION_S;
      };
      measure();
      new ResizeObserver(measure).observe(groups[0]);

      const wrap = (val) => {
        if (!halfWidth) return val;
        while (val <= -halfWidth) val += halfWidth;
        while (val > 0) val -= halfWidth;
        return val;
      };

      function frame(now) {
        if (!lastFrame) lastFrame = now;
        const dt = Math.min(0.05, (now - lastFrame) / 1000);
        lastFrame = now;

        if (!dragging && !paused) {
          // Momentum carries until it decays below |AUTO_SPEED|, then idle drift.
          const sinceRelease = now - releasedAt;
          const holdingOff = releasedAt && sinceRelease < RESUME_MS && Math.abs(vel) > Math.abs(autoSpeed);
          if (Math.abs(vel) > Math.abs(autoSpeed)) {
            x += vel * dt;
            vel *= Math.exp(-FRICTION * dt);
          } else {
            x += (holdingOff ? 0 : autoSpeed) * dt;
            vel = 0;
          }
          x = wrap(x);
          track.style.transform = 'translateX(' + x + 'px)';
        }
        requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);

      viewport.addEventListener('mouseenter', () => { paused = true; });
      viewport.addEventListener('mouseleave', () => { paused = false; });

      const onDown = (e) => {
        dragging = true;
        paused = false;
        vel = 0;
        samples = [[performance.now(), e.clientX]];
        track.setPointerCapture && track.setPointerCapture(e.pointerId);
        e.preventDefault();
      };
      const onMove = (e) => {
        if (!dragging) return;
        const now = performance.now();
        const prev = samples[samples.length - 1];
        const dx = e.clientX - prev[1];
        x = wrap(x + dx);
        track.style.transform = 'translateX(' + x + 'px)';
        samples.push([now, e.clientX]);
        // Trim samples older than 100ms for a snappy release velocity.
        while (samples.length > 2 && now - samples[0][0] > 100) samples.shift();
      };
      const onUp = (e) => {
        if (!dragging) return;
        dragging = false;
        const now = performance.now();
        const first = samples[0];
        const dt = Math.max(1, now - first[0]) / 1000;
        const dx = e.clientX - first[1];
        vel = Math.max(-MAX_VEL, Math.min(MAX_VEL, dx / dt));
        releasedAt = now;
        track.releasePointerCapture && track.releasePointerCapture(e.pointerId);
      };
      track.addEventListener('pointerdown', onDown);
      track.addEventListener('pointermove', onMove);
      track.addEventListener('pointerup', onUp);
      track.addEventListener('pointercancel', onUp);
      // Block link-clicks that happen after a real drag gesture.
      track.addEventListener('click', (e) => {
        const first = samples[0];
        if (!first) return;
        const total = Math.abs(e.clientX - first[1]);
        if (total > 8) { e.preventDefault(); e.stopPropagation(); }
      }, true);
    }
  })();
</script>
