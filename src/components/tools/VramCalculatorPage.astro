// Init Selects
function initSelects() {
  MACS.forEach(mac => {
    const opt = document.createElement('option');
    opt.value = mac.id;
    opt.textContent = mac.name;
    if (mac.id === 'm5-pro') opt.selected = true;
    els.macSelect.appendChild(opt);
  });
  updateRamOptions();
}

function updateRamOptions() {
  const mac = MACS.find(m => m.id === els.macSelect.value) || MACS[15];
  const currentRam = parseFloat(els.ramSelect.value) || 16;

  els.ramSelect.innerHTML = '';
  let closestMatch = mac.ram[0];

  mac.ram.forEach(r => {
    const opt = document.createElement('option');
    opt.value = r.toString();
    opt.textContent = r + ' GB';
    els.ramSelect.appendChild(opt);

    if (Math.abs(r - currentRam) < Math.abs(closestMatch - currentRam)) {
      closestMatch = r;
    }
  });

  els.ramSelect.value = closestMatch.toString();
}

els.macSelect.addEventListener('change', () => {
  updateRamOptions();
  calculate();
});

// Logic Engine
function calculate() {
  const mac = MACS.find(m => m.id === els.macSelect.value) || MACS[15];
  const ramGB = parseFloat(els.ramSelect.value) || 16;
  const osVer = parseInt(els.osSelect.value) || 14;
  const fw = els.fwSelect.value;

  els.macSpecs.textContent = `${STR.specsBandwidth}: ${mac.bw} GB/s | ${STR.specsNeuralEngine}: ${mac.ne}-core`;

  const p = parseFloat(els.params.value) || 0;
  const bytesPerParam = parseFloat(els.precision.value) || 2;
  const ctx = parseFloat(els.context.value) || 0;
  const batch = parseFloat(els.batch.value) || 1;
  const layers = parseFloat(els.layers.value) || 1;
  const hidden = parseFloat(els.hiddenSize.value) || 1;
  const att = parseFloat(els.attHeads.value) || 1;
  const kv = parseFloat(els.kvHeads.value) || 1;

  const weightsGB = (p * 1e9 * bytesPerParam) / (1024 ** 3);

  const headDim = hidden / att;
  const bytesPerToken = 2 * layers * kv * headDim * bytesPerParam;
  let kvCacheGB = (ctx * batch * bytesPerToken) / (1024 ** 3);

  if (fw === 'vllm') kvCacheGB *= 1.2;

  let fwOverhead = 0.2;
  if (fw === 'ollama') fwOverhead = 0.6;
  if (fw === 'vllm') fwOverhead = 1.0;
  const activationGB = fwOverhead + (ctx * batch * 0.0001);

  const osOverhead = osVer >= 15 ? 2.5 + (ramGB * 0.05) : 1.5 + (ramGB * 0.05);

  const totalReqGB = weightsGB + kvCacheGB + activationGB + osOverhead;

  els.weightsOut.textContent = weightsGB.toFixed(2);
  els.kvOut.textContent = kvCacheGB.toFixed(2);
  els.actOut.textContent = activationGB.toFixed(2);
  els.osOverheadOut.textContent = osOverhead.toFixed(2);
  els.totalOut.textContent = totalReqGB.toFixed(2);
  els.availRamOut.textContent = ramGB.toString();

  const wPct = (weightsGB / ramGB) * 100;
  const kvPct = (kvCacheGB / ramGB) * 100;
  const actPct = (activationGB / ramGB) * 100;
  const osPct = (osOverhead / ramGB) * 100;
  const totalPct = wPct + kvPct + actPct + osPct;

  if (totalPct > 100) {
    els.progWeights.style.width = '0%';
    els.progKv.style.width = '0%';
    els.progAct.style.width = '0%';
    els.progOs.style.width = '0%';
    els.progDanger.style.width = '100%';
  } else {
    els.progWeights.style.width = `${wPct}%`;
    els.progKv.style.width = `${kvPct}%`;
    els.progAct.style.width = `${actPct}%`;
    els.progOs.style.width = `${osPct}%`;
    els.progDanger.style.width = `0%`;
  }

  let efficiency = 0.85;
  if (fw === 'ollama') efficiency = 0.65;
  if (fw === 'vllm') efficiency = 0.70;
  if (fw === 'sglang') efficiency = 0.88;

  let throughput = (mac.bw * efficiency) / (weightsGB || 1);
  if (throughput > 200) throughput = 200;

  let ttft = (ctx / 1000) * (16 / mac.ne) * 0.05;
  if (ttft < 0.1) ttft = 0.1;

  if (totalReqGB > ramGB) {
    throughput = throughput * 0.1;
    ttft = ttft * 5;
  }

  let powerW = mac.tdp * 0.8;
  if (totalReqGB > ramGB) powerW = mac.tdp;
  let costPerHr = (powerW / 1000) * 0.15;
  let emissionsPerHr = (powerW / 1000) * 385;

  els.throughputOut.textContent = Math.round(throughput).toString();
  els.ttftOut.textContent = ttft.toFixed(2);
  els.powerOut.textContent = Math.round(powerW).toString();
  els.costOut.textContent = costPerHr.toFixed(3);
  els.emissionsOut.textContent = Math.round(emissionsPerHr).toString();

  if (totalReqGB > ramGB * 1.1) {
    els.verdictBanner.className = "mb-5 p-3 rounded-lg bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-300 border border-red-200 dark:border-red-800/50 text-sm font-medium";
    els.verdictBanner.textContent = STR.ratingCannotRun;
  } else if (totalReqGB > ramGB * 0.9) {
    els.verdictBanner.className = "mb-5 p-3 rounded-lg bg-orange-100 dark:bg-orange-900/30 text-orange-800 dark:text-orange-300 border border-orange-200 dark:border-orange-800/50 text-sm font-medium";
    els.verdictBanner.textContent = STR.ratingBad;
  } else if (throughput >= 30) {
    els.verdictBanner.className = "mb-5 p-3 rounded-lg bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300 border border-green-200 dark:border-green-800/50 text-sm font-medium";
    els.verdictBanner.textContent = STR.ratingGodTier;
  } else {
    els.verdictBanner.className = "mb-5 p-3 rounded-lg bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-300 border border-blue-200 dark:border-blue-800/50 text-sm font-medium";
    els.verdictBanner.textContent = STR.ratingGood;
  }

  let cmd = '';
  let modelName = els.searchInput.value || 'local-model';

  const curatedMatch = CURATED_MODELS.find(m => m.name === modelName);
  if (curatedMatch) modelName = curatedMatch.id;

  if (fw === 'ollama') {
    let cleanName = modelName.split('/').pop()?.toLowerCase() || 'model';
    cmd = `ollama run ${cleanName}`;
  } else if (fw === 'mlx') {
    cmd = `mlx_lm.generate --model ${modelName} --prompt "Hello"`;
  } else if (fw === 'vllm') {
    cmd = `python -m vllm.entrypoints.openai.api_server --model ${modelName}`;
  } else if (fw === 'sglang') {
    cmd = `python -m sglang.launch_server --model-path ${modelName} --port 3000`;
  }

  if (els.deployCmdOut) {
    els.deployCmdOut.textContent = cmd;
  }

  // Update install hint
  els.installHintLabel.textContent = STR.deployInstallHint;
  els.installHintCmd.textContent = INSTALL_HINTS[fw] || INSTALL_HINTS.mlx;

  updateRecommendations(mac, ramGB, osVer, fw);
}

function updateRecommendations(mac: any, ramGB: number, osVer: number, fw: string) {
  els.recList.innerHTML = '';
  els.recEmpty.classList.add('hidden');

  const bytesPerParam = parseFloat(els.precision.value) || 0.5;

  const validModels = CURATED_MODELS.map(m => {
    const weightsGB = (m.params * 1e9 * bytesPerParam) / (1024 ** 3);
    const headDim = m.hidden / m.att;
    const bytesPerToken = 2 * m.layers * m.kv * headDim * bytesPerParam;

    let kvCacheGB = (4096 * 1 * bytesPerToken) / (1024 ** 3);
    if (fw === 'vllm') kvCacheGB *= 1.2;

    let fwOverhead = 0.2;
    if (fw === 'ollama') fwOverhead = 0.6;
    if (fw === 'vllm') fwOverhead = 1.0;
    const activationGB = fwOverhead + (4096 * 1 * 0.0001);

    const osOverhead = osVer >= 15 ? 2.5 + (ramGB * 0.05) : 1.5 + (ramGB * 0.05);
    const totalReqGB = weightsGB + kvCacheGB + activationGB + osOverhead;

    let efficiency = 0.85;
    if (fw === 'ollama') efficiency = 0.65;
    if (fw === 'vllm') efficiency = 0.70;
    if (fw === 'sglang') efficiency = 0.88;

    let throughput = (mac.bw * efficiency) / (weightsGB || 1);
    if (throughput > 200) throughput = 200;

    return { ...m, fits: totalReqGB <= ramGB * 0.95, ts: Math.round(throughput) };
  }).filter(m => m.fits).sort((a, b) => b.params - a.params);

  if (validModels.length === 0) {
    els.recEmpty.classList.remove('hidden');
    return;
  }

  const topRecommendations = validModels.slice(0, 3);

  topRecommendations.forEach(m => {
    const div = document.createElement('div');
    div.className = "flex items-center justify-between p-3 rounded-xl border border-gray-100 dark:border-gray-800 hover:border-orange-500/50 hover:bg-orange-50 dark:hover:bg-orange-500/10 cursor-pointer transition-colors group";

    div.innerHTML = `
      <div>
        <h3 class="font-medium text-gray-900 dark:text-gray-100 group-hover:text-orange-600 dark:group-hover:text-orange-400 transition-colors">${m.name}</h3>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">${m.params}B Params <span class="mx-1">•</span> <span class="font-medium text-indigo-500 dark:text-indigo-400">${m.role || 'General Purpose'}</span></p>
      </div>
      <div class="text-right">
        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 text-xs font-semibold">
          ~${m.ts} ${STR.recommendedBadge}
        </span>
      </div>
    `;

    div.addEventListener('click', () => {
      const fullModel = CURATED_MODELS.find(cm => cm.id === m.id);
      if (fullModel) {
        applyModelData(fullModel);
        els.searchInput.value = fullModel.name;
        els.autoList.classList.add('hidden');
      }
    });

    els.recList.appendChild(div);
  });
}

// Search Autocomplete Logic
let hfTimeout: number;
els.searchInput.addEventListener('input', (e) => {
  const val = (e.target as HTMLInputElement).value.toLowerCase();
  els.autoResults.innerHTML = '';

  if (!val) {
    els.autoList.classList.add('hidden');
    clearTimeout(hfTimeout);
    return;
  }

  els.autoList.classList.remove('hidden');

  const matches = CURATED_MODELS.filter(m => m.name.toLowerCase().includes(val) || m.id.includes(val));

  matches.forEach(m => {
    const div = document.createElement('div');
    div.className = "px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer border-b border-gray-100 dark:border-gray-800 last:border-0";
    div.innerHTML = `<div class="font-medium text-gray-900 dark:text-gray-100">${m.name}</div><div class="text-xs text-gray-500">${m.params}B Params</div>`;
    div.addEventListener('click', () => {
      els.searchInput.value = m.name;
      els.autoList.classList.add('hidden');
      applyModelData(m);
      clearTimeout(hfTimeout);
    });
    els.autoResults.appendChild(div);
  });

  if (matches.length === 0) {
    els.autoResults.innerHTML = `<div class="px-4 py-3 text-sm text-gray-500 italic">${STR.hfSearchingLabel}</div>`;
  }

  clearTimeout(hfTimeout);
  hfTimeout = setTimeout(() => {
    searchHuggingFace(val);
  }, 500) as unknown as number;
});

els.searchInput.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') {
    e.preventDefault();
    clearTimeout(hfTimeout);
    searchHuggingFace(els.searchInput.value);
  }
});

document.addEventListener('click', (e) => {
  if (!els.autoList.contains(e.target as Node) && e.target !== els.searchInput) {
    els.autoList.classList.add('hidden');
  }
});

async function searchHuggingFace(query: string) {
  if (!query) return;

  try {
    const res = await fetch(`https://huggingface.co/api/models?search=${encodeURIComponent(query)}&limit=15&sort=downloads`);
    const data = await res.json();

    const localMatches = CURATED_MODELS.filter(m => m.name.toLowerCase().includes(query.toLowerCase()) || m.id.includes(query.toLowerCase()));

    if (localMatches.length === 0) {
      els.autoResults.innerHTML = '';
    } else {
      const lastChild = els.autoResults.lastElementChild;
      if (lastChild && lastChild.classList.contains('italic')) {
        els.autoResults.removeChild(lastChild);
      }

      if (data && data.length > 0) {
         const div = document.createElement('div');
         div.className = "px-4 py-1 text-xs font-bold text-gray-400 bg-gray-50 dark:bg-gray-900 border-b border-gray-100 dark:border-gray-800 uppercase";
         div.textContent = STR.hfResultsLabel;
         els.autoResults.appendChild(div);
      }
    }

    if (!data || data.length === 0) {
      if (localMatches.length === 0) {
        els.autoResults.innerHTML = `<div class="px-4 py-3 text-sm text-gray-500 italic">${STR.hfNoResults}</div>`;
      }
      return;
    }

    data.forEach((m: any) => {
      const div = document.createElement('div');
      div.className = "px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer border-b border-gray-100 dark:border-gray-800 last:border-0";
      div.innerHTML = `<div class="font-medium text-blue-600 dark:text-blue-400 break-all">${m.id}</div><div class="text-xs text-gray-500 flex gap-2 mt-0.5"><span>⬇ ${m.downloads?.toLocaleString() || 0}</span><span class="bg-gray-100 dark:bg-gray-800 px-1.5 rounded">${STR.hfApiLabel}</span></div>`;
      div.addEventListener('click', () => {
        els.searchInput.value = m.id;
        els.autoList.classList.add('hidden');
        fetchHuggingFaceConfig(m.id);
      });
      els.autoResults.appendChild(div);
    });
  } catch (err) {
    // Ignore fetch errors during typing
  }
}

async function fetchHuggingFaceConfig(modelId: string) {
  els.searchInput.value = `${STR.hfLoadingModel} ${modelId}...`;

  const lowerId = modelId.toLowerCase();
  let guessedPrecision = 2;

  if (lowerId.includes('fp32') || lowerId.includes('f32')) guessedPrecision = 4;
  else if (lowerId.includes('int8') || lowerId.includes('q8') || lowerId.includes('8bpw')) guessedPrecision = 1;
  else if (lowerId.includes('int4') || lowerId.includes('q4') || lowerId.includes('4bpw') || lowerId.includes('exl2-4') || lowerId.includes('awq') || lowerId.includes('gguf')) guessedPrecision = 0.5;
  else if (lowerId.includes('q3') || lowerId.includes('3bpw')) guessedPrecision = 0.375;
  else if (lowerId.includes('q2') || lowerId.includes('2bpw')) guessedPrecision = 0.25;

  try {
    const res = await fetch(`https://huggingface.co/${modelId}/raw/main/config.json`);
    if (!res.ok) throw new Error('Not found or private');
    const config = await res.json();

    let layers = config.num_hidden_layers || 32;
    let hidden = config.hidden_size || 4096;
    let att = config.num_attention_heads || 32;
    let kv = config.num_key_value_heads || att;

    let pMatch = modelId.match(/(\d+(?:\.\d+)?)[bB](?![a-zA-Z])/i);
    let params = pMatch ? parseFloat(pMatch[1]) : 0;

    if (params === 0) {
      params = Math.round((layers * hidden * hidden * 12) / 1e9) || 8;
    }

    applyModelData({
      params, layers, hidden, att, kv, precision: guessedPrecision
    });
    els.searchInput.value = modelId;
    } catch (err) {
    let pMatch = modelId.match(/(\d+(?:\.\d+)?)[bB](?![a-zA-Z])/i);
    let params = pMatch ? parseFloat(pMatch[1]) : 8;

    const banner = els.verdictBanner;
    const origText = banner.textContent;
    const origClass = banner.className;
    banner.className = "mb-5 p-3 rounded-lg bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-300 border border-yellow-200 dark:border-yellow-800/50 text-sm font-medium";
    banner.textContent = STR.hfFetchError;
    setTimeout(() => { banner.textContent = origText; banner.className = origClass; }, 4000);

    els.params.value = params.toString();
    els.precision.value = guessedPrecision.toString();
    calculate();

    els.searchInput.value = modelId;
  }
}

function applyModelData(data: any) {
  els.params.value = data.params;
  els.layers.value = data.layers;
  els.hiddenSize.value = data.hidden;
  els.attHeads.value = data.att;
  els.kvHeads.value = data.kv;
  if (data.precision !== undefined) {
    els.precision.value = data.precision.toString();
  } else {
    els.precision.value = "0.5";
  }
  calculate();
}

// Bind events
[els.ramSelect, els.osSelect, els.fwSelect, els.params, els.precision, els.context, els.batch, els.layers, els.hiddenSize, els.attHeads, els.kvHeads].forEach(el => {
  el.addEventListener('input', calculate);
});

// Run init
initSelects();
calculate();
</script>
