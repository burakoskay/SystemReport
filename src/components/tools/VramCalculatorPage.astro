---
import Layout from '../../layouts/Layout.astro';
import {
  HREFLANG,
  LOCALE_LIST,
  RTL_LOCALES,
  localeToSlug,
  type Locale,
} from '../../i18n/tool-strings';
import { VRAM_STRINGS } from '../../i18n/vram-strings';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const s = VRAM_STRINGS[locale] || VRAM_STRINGS.en;
const isRtl = RTL_LOCALES.has(locale);

const pathFor = (l: Locale) =>
  l === 'en' ? '/tools/vram-calculator/' : `/${localeToSlug(l)}/tools/vram-calculator/`;
const canonical = `https://www.systemreport.net${pathFor(locale)}`;

const hreflangAlternates = LOCALE_LIST.map((l) => ({
  hreflang: HREFLANG[l],
  href: `https://www.systemreport.net${pathFor(l)}`,
}));

const schema = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: s.metaTitle,
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any (runs in web browser)',
    inLanguage: HREFLANG[locale],
    url: canonical,
    description: s.metaDescription,
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    inLanguage: HREFLANG[locale],
    mainEntity: s.faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: s.h1,
    description: s.metaDescription,
    inLanguage: HREFLANG[locale],
    step: [
      { '@type': 'HowToStep', position: 1, name: s.hardwareSettingsLabel, text: s.macFamilyLabel },
      { '@type': 'HowToStep', position: 2, name: s.modelSettingsLabel, text: s.modelSearchLabel },
      { '@type': 'HowToStep', position: 3, name: s.resultsTitle, text: s.totalMemory },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: s.breadcrumbHome, item: locale === 'en' ? 'https://www.systemreport.net/' : `https://www.systemreport.net/${localeToSlug(locale)}/` },
      { '@type': 'ListItem', position: 2, name: s.breadcrumbTools, item: locale === 'en' ? 'https://www.systemreport.net/tools/' : `https://www.systemreport.net/${localeToSlug(locale)}/tools/` },
      { '@type': 'ListItem', position: 3, name: s.breadcrumbTool, item: canonical },
    ],
  },
]);

const strongRe = /\{strong\}(.*?)\{\/strong\}/;
const m = s.subtitle.match(strongRe);
const subtitleBefore = m ? s.subtitle.slice(0, m.index) : s.subtitle;
const subtitleStrong = m ? m[1] : '';
const subtitleAfter = m ? s.subtitle.slice((m.index ?? 0) + m[0].length) : '';

const toolsHref = locale === 'en' ? '/tools/' : `/${localeToSlug(locale)}/tools/`;
const homeHref = locale === 'en' ? '/' : `/${localeToSlug(locale)}/`;

const jsStrings = JSON.stringify({
  ratingGodTier: s.ratingGodTier,
  ratingGood: s.ratingGood,
  ratingBad: s.ratingBad,
  ratingCannotRun: s.ratingCannotRun,
  recommendedBadge: s.recommendedBadge,
  specsBandwidth: s.specsBandwidth,
  specsNeuralEngine: s.specsNeuralEngine,
  hfResultsLabel: s.hfResultsLabel,
  hfSearchingLabel: s.hfSearchingLabel,
  hfNoResults: s.hfNoResults,
  hfApiLabel: s.hfApiLabel,
  hfLoadingModel: s.hfLoadingModel,
  hfFetchError: s.hfFetchError,
  deployCopied: s.deployCopied,
  deployInstallHint: s.deployInstallHint,
  deployInstallHintOllama: s.deployInstallHintOllama,
  deployInstallHintVllm: s.deployInstallHintVllm,
  deployInstallHintSglang: s.deployInstallHintSglang,
  deployInstallHintMlx: s.deployInstallHintMlx,
  usedLabel: s.usedLabel,
  availableLabel: s.availableLabel,
});
---

<Layout
  title={s.metaTitle}
  description={s.metaDescription}
  schema={schema}
  url={canonical}
  lang={HREFLANG[locale]}
  hreflangAlternates={hreflangAlternates}
>
  <div class="max-w-6xl mx-auto" dir={isRtl ? 'rtl' : 'ltr'}>
    <nav class="mb-6 text-sm text-gray-500 dark:text-gray-400" aria-label="Breadcrumb">
      <a href={homeHref} class="hover:text-gray-900 dark:hover:text-gray-100">{s.breadcrumbHome}</a>
      <span class="mx-2">/</span>
      <a href={toolsHref} class="hover:text-gray-900 dark:hover:text-gray-100">{s.breadcrumbTools}</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900 dark:text-gray-100">{s.breadcrumbTool}</span>
    </nav>

    <header class="mb-8">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gray-500 dark:text-gray-400 mb-3">
        {s.eyebrow}
      </p>
      <h1 class="font-serif text-4xl sm:text-5xl font-bold text-gray-900 dark:text-gray-100 mb-4 tracking-tight">
        {s.h1}
      </h1>
      <p class="text-lg text-gray-500 dark:text-gray-400 leading-relaxed max-w-3xl">
        {subtitleBefore}<strong class="text-gray-900 dark:text-gray-100 font-semibold">{subtitleStrong}</strong>{subtitleAfter}
      </p>
    </header>

    <section id="tool" class="mb-12 grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 items-start">
      <!-- Calculator Form -->
      <div class="lg:col-span-7 space-y-6">

        <!-- Hardware Settings Panel -->
        <div class="bg-white dark:bg-gray-950 p-6 sm:p-8 rounded-2xl border border-gray-200 dark:border-gray-800 shadow-sm">
          <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-5">{s.hardwareSettingsLabel}</h2>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
            <div>
              <label for="mac-select" class="block text-sm font-medium text-gray-900 dark:text-gray-100 mb-1">{s.macFamilyLabel}</label>
              <select id="mac-select" class="w-full bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-gray-900 dark:focus:ring-gray-100 focus:border-transparent transition-colors">
                <!-- Injected via JS -->
              </select>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-1" id="mac-specs-text"></p>
            </div>

            <div>
              <label for="ram-select" class="block text-sm font-medium text-gray-900 dark:text-gray-100 mb-1">{s.macRamLabel}</label>
              <select id="ram-select" class="w-full bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-gray-900 dark:focus:ring-gray-100 focus:border-transparent transition-colors">
                <option value="8">8 GB</option>
                <option value="16" selected>16 GB</option>
                <option value="24">24 GB</option>
                <option value="32">32 GB</option>
                <option value="36">36 GB</option>
                <option value="48">48 GB</option>
                <option value="64">64 GB</option>
                <option value="96">96 GB</option>
                <option value="128">128 GB</option>
                <option value="192">192 GB</option>
              </select>
            </div>

            <div>
              <label for="os-select" class="block text-sm font-medium text-gray-900 dark:text-gray-100 mb-1">{s.macOsLabel}</label>
              <select id="os-select" class="w-full bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-gray-900 dark:focus:ring-gray-100 focus:border-transparent transition-colors">
                <option value="16">macOS 16 Tahoe</option>
                <option value="15">macOS 15 Sequoia</option>
                <option value="14" selected>macOS 14 Sonoma</option>
                <option value="13">macOS 13 Ventura</option>
              </select>
            </div>

            <div>
              <label for="framework-select" class="block text-sm font-medium text-gray-900 dark:text-gray-100 mb-1">{s.frameworkLabel}</label>
              <select id="framework-select" class="w-full bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-gray-900 dark:focus:ring-gray-100 focus:border-transparent transition-colors">
                <option value="mlx" selected>MLX (Apple Native)</option>
                <option value="ollama">Ollama (llama.cpp)</option>
                <option value="vllm">vLLM (Pre-alloc KV)</option>
                <option value="sglang">SGLang (High Throughput)</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Model Configuration Panel -->
        <div class="bg-white dark:bg-gray-950 p-6 sm:p-8 rounded-2xl border border-gray-200 dark:border-gray-800 shadow-sm relative z-10">
          <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-5">{s.modelSettingsLabel}</h2>

          <div class="mb-6 relative">
            <label for="model-search" class="block text-sm font-medium text-gray-900 dark:text-gray-100 mb-1">{s.modelSearchLabel}</label>
            <div class="relative">
              <input type="text" id="model-search" placeholder={s.modelSearchPlaceholder} class="w-full bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg pl-10 pr-4 py-3 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-gray-900 dark:focus:ring-gray-100 focus:border-transparent transition-colors" autocomplete="off" />
              <svg class="w-5 h-5 absolute left-3 top-3.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </div>

            <!-- Custom Autocomplete Dropdown -->
            <div id="autocomplete-list" class="absolute w-full mt-1 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg shadow-xl overflow-hidden hidden max-h-80 overflow-y-auto z-50">
              <div id="autocomplete-results"></div>
              <div id="autocomplete-loading" class="hidden px-4 py-3 text-sm text-gray-500 dark:text-gray-400 flex items-center justify-center">
                <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-gray-500 dark:text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                {s.modelSearchLivePlaceholder}
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <!-- Parameters -->
            <div>
              <label for="params-input" class="block text-sm font-medium text-gray-900 dark:text-gray-100 mb-1">{s.paramsLabel}</label>
              <p class="text-xs text-gray-500 dark:text-gray-400 mb-2">{s.paramsDesc}</p>
              <input type="number" id="params-input" value="8" min="0.1" step="any" class="w-full bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-gray-900 dark:focus:ring-gray-100"/>
            </div>

            <!-- Precision -->
            <div>
              <label for="precision-select" class="block text-sm font-medium text-gray-900 dark:text-gray-100 mb-1">{s.precisionLabel}</label>
              <p class="text-xs text-gray-500 dark:text-gray-400 mb-2">{s.precisionDesc}</p>
              <select id="precision-select" class="w-full bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-gray-900 dark:focus:ring-gray-100">
                <option value="4">FP32 (4 bytes)</option>
                <option value="2">FP16 / BF16 (2 bytes)</option>
                <option value="1">INT8 / Q8 (1 byte)</option>
                <option value="0.5" selected>INT4 / Q4 (0.5 bytes)</option>
                <option value="0.375">3-bit (0.375 bytes)</option>
                <option value="0.25">2-bit (0.25 bytes)</option>
              </select>
            </div>

            <!-- Context Window -->
            <div>
              <label for="context-input" class="block text-sm font-medium text-gray-900 dark:text-gray-100 mb-1">{s.contextLabel}</label>
              <p class="text-xs text-gray-500 dark:text-gray-400 mb-2">{s.contextDesc}</p>
              <input type="number" id="context-input" value="8192" min="1" class="w-full bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-gray-900 dark:focus:ring-gray-100"/>
            </div>

            <!-- Batch Size -->
            <div>
              <label for="batch-input" class="block text-sm font-medium text-gray-900 dark:text-gray-100 mb-1">{s.batchLabel}</label>
              <p class="text-xs text-gray-500 dark:text-gray-400 mb-2">{s.batchDesc}</p>
              <input type="number" id="batch-input" value="1" min="1" class="w-full bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-gray-900 dark:focus:ring-gray-100"/>
            </div>
          </div>

          <details class="group mt-6 border-t border-gray-200 dark:border-gray-800 pt-5">
            <summary class="font-medium text-sm text-gray-700 dark:text-gray-300 cursor-pointer list-none flex items-center justify-between">
              <span>{s.advancedSettingsLabel}</span>
              <svg class="w-4 h-4 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
            </summary>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4 text-sm">
              <div>
                <label for="layers-input" class="block font-medium text-gray-900 dark:text-gray-100 mb-1">{s.layersLabel}</label>
                <input type="number" id="layers-input" value="32" class="w-full bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-1.5 text-gray-900 dark:text-gray-100"/>
              </div>
              <div>
                <label for="hidden-size-input" class="block font-medium text-gray-900 dark:text-gray-100 mb-1">{s.hiddenSizeLabel}</label>
                <input type="number" id="hidden-size-input" value="4096" class="w-full bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-1.5 text-gray-900 dark:text-gray-100"/>
              </div>
              <div>
                <label for="attention-heads-input" class="block font-medium text-gray-900 dark:text-gray-100 mb-1">{s.attentionHeadsLabel}</label>
                <input type="number" id="attention-heads-input" value="32" class="w-full bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-1.5 text-gray-900 dark:text-gray-100"/>
              </div>
              <div>
                <label for="kv-heads-input" class="block font-medium text-gray-900 dark:text-gray-100 mb-1">{s.kvHeadsLabel}</label>
                <input type="number" id="kv-heads-input" value="8" class="w-full bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-1.5 text-gray-900 dark:text-gray-100"/>
              </div>
            </div>
          </details>
        </div>

        <!-- Recommended Models Card -->
        <div class="bg-white dark:bg-gray-950 border border-gray-200 dark:border-gray-800 p-6 sm:p-8 rounded-2xl shadow-sm mt-6">
          <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-5">{s.recommendedTitle}</h2>
          <div id="recommended-empty" class="text-sm text-gray-500 dark:text-gray-400 hidden">
            {s.recommendedEmpty}
          </div>
          <div id="recommended-list" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <!-- Injected via JS -->
          </div>
        </div>
      </div>

      <!-- Results Panel -->
      <div class="lg:col-span-5 space-y-6 z-0">

        <!-- Breakdown Card -->
        <div class="bg-gray-900 dark:bg-white text-white dark:text-gray-900 p-6 sm:p-8 rounded-2xl shadow-xl relative overflow-hidden border border-gray-800 dark:border-gray-200">

          <div class="relative z-10">
            <h2 class="font-serif text-xl font-bold mb-6 flex items-center justify-between">
              {s.resultsTitle}
              <svg class="w-5 h-5 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </h2>

            <div class="mb-8">
              <p class="text-sm text-gray-400 dark:text-gray-500 mb-1 font-medium">{s.totalMemory}</p>
              <p class="text-5xl font-extrabold tracking-tight drop-shadow-sm text-orange-500"><span id="total-memory-output">0.0</span> <span class="text-2xl font-bold text-gray-500 dark:text-gray-400">GB</span></p>

              <!-- Compatibility Progress Bar -->
              <div class="mt-4 bg-gray-800 dark:bg-gray-200 rounded-full h-1.5 overflow-hidden flex">
                <div id="progress-weights" class="bg-blue-400 h-full transition-all duration-500 ease-out" style="width: 0%"></div>
                <div id="progress-kv" class="bg-purple-400 h-full transition-all duration-500 ease-out" style="width: 0%"></div>
                <div id="progress-act" class="bg-pink-400 h-full transition-all duration-500 ease-out" style="width: 0%"></div>
                <div id="progress-os" class="bg-gray-500 dark:bg-gray-400 h-full transition-all duration-500 ease-out" style="width: 0%"></div>
                <div id="progress-danger" class="bg-red-500 h-full transition-all duration-500 ease-out" style="width: 0%"></div>
              </div>
              <div class="flex justify-between mt-2 text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider">
                <span id="used-label"></span>
                <span><span id="available-label"></span>: <span id="avail-ram-output">16</span> GB</span>
              </div>
            </div>

            <div class="space-y-3 text-sm font-medium">
              <div class="flex justify-between items-center pb-3 border-b border-gray-800 dark:border-gray-200">
                <span class="text-gray-300 dark:text-gray-700 flex items-center gap-2"><span class="w-2.5 h-2.5 rounded-full bg-blue-400"></span>{s.modelWeights}</span>
                <span><span id="weights-output">0.0</span> GB</span>
              </div>
              <div class="flex justify-between items-center pb-3 border-b border-gray-800 dark:border-gray-200">
                <span class="text-gray-300 dark:text-gray-700 flex items-center gap-2"><span class="w-2.5 h-2.5 rounded-full bg-purple-400"></span>{s.kvCache}</span>
                <span><span id="kv-output">0.0</span> GB</span>
              </div>
              <div class="flex justify-between items-center pb-3 border-b border-gray-800 dark:border-gray-200">
                <span class="text-gray-300 dark:text-gray-700 flex items-center gap-2"><span class="w-2.5 h-2.5 rounded-full bg-pink-400"></span>{s.frameworkOverhead} &amp; Acts.</span>
                <span><span id="activation-output">1.0</span> GB</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-gray-300 dark:text-gray-700 flex items-center gap-2"><span class="w-2.5 h-2.5 rounded-full bg-gray-500 dark:bg-gray-400"></span>{s.macOsOverhead}</span>
                <span><span id="os-overhead-output">2.0</span> GB</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Performance Estimates Card -->
        <div class="bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 p-6 rounded-2xl">
          <div id="verdict-banner" class="mb-5 p-3 rounded-lg bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300 border border-green-200 dark:border-green-800/50 text-sm font-medium">
            {s.ratingGodTier}
          </div>

          <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-4">
            <div>
              <p class="text-xs text-gray-500 dark:text-gray-400 font-medium uppercase tracking-wider mb-1">{s.throughputLabel}</p>
              <p class="text-xl font-bold text-gray-900 dark:text-gray-100">~<span id="throughput-output">0</span> <span class="text-sm font-normal text-gray-500">t/s</span></p>
            </div>
            <div>
              <p class="text-xs text-gray-500 dark:text-gray-400 font-medium uppercase tracking-wider mb-1">{s.ttftLabel}</p>
              <p class="text-xl font-bold text-gray-900 dark:text-gray-100">&lt;<span id="ttft-output">0.5</span> <span class="text-sm font-normal text-gray-500">s</span></p>
            </div>
            <div>
              <p class="text-xs text-gray-500 dark:text-gray-400 font-medium uppercase tracking-wider mb-1">{s.powerDrawLabel}</p>
              <p class="text-xl font-bold text-gray-900 dark:text-gray-100"><span id="power-output">0</span> <span class="text-sm font-normal text-gray-500">W</span></p>
            </div>
          </div>

          <div class="pt-4 border-t border-gray-200 dark:border-gray-800 grid grid-cols-2 gap-4">
            <div>
              <p class="text-xs text-gray-500 dark:text-gray-400 font-medium uppercase tracking-wider mb-1">{s.costPerHrLabel}</p>
              <p class="text-sm font-bold text-gray-900 dark:text-gray-100">$<span id="cost-output">0.00</span></p>
            </div>
            <div>
              <p class="text-xs text-gray-500 dark:text-gray-400 font-medium uppercase tracking-wider mb-1">{s.emissionsPerHrLabel}</p>
              <p class="text-sm font-bold text-gray-900 dark:text-gray-100"><span id="emissions-output">0</span> <span class="text-xs font-normal text-gray-500">gCO₂e</span></p>
            </div>
          </div>
        </div>

        <!-- Quick Start Card -->
        <div class="bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 p-6 rounded-2xl shadow-sm">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-sm font-bold text-gray-900 dark:text-gray-100 uppercase tracking-wide">{s.deployTitle}</h3>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">{s.deployDesc}</p>

          <!-- Main command with copy button -->
          <div class="relative group">
            <div class="bg-gray-900 dark:bg-black rounded-lg p-4 pr-12 font-mono text-sm text-green-400 overflow-x-auto border border-gray-800">
              <span class="text-gray-500 select-none">$ </span><span id="deploy-command-output" class="whitespace-nowrap select-all">mlx_lm.generate --model meta-llama/Meta-Llama-3-8B</span>
            </div>
            <button
              id="copy-command-btn"
              type="button"
              class="absolute top-2.5 right-2.5 p-1.5 rounded-md bg-gray-800 hover:bg-gray-700 dark:bg-gray-900 dark:hover:bg-gray-800 text-gray-400 hover:text-white transition-colors opacity-0 group-hover:opacity-100 focus:opacity-100"
              aria-label="Copy command"
            >
