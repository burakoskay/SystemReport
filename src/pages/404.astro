---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found | System Report" description="The page you're looking for doesn't exist.">
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <div class="text-8xl font-serif font-bold text-gray-200 dark:text-gray-800 mb-4">
      404
    </div>
    <h1 class="text-2xl font-serif font-bold text-gray-900 dark:text-gray-100 mb-3">
      Signal lost
    </h1>
    <p class="text-gray-500 dark:text-gray-400 mb-8 max-w-md">
      The page you're looking for doesn't exist, was removed, or the URL is incorrect.
    </p>
    <div class="flex items-center gap-3">
      <a
        href="/"
        class="px-5 py-2.5 bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 text-white text-sm font-medium rounded-xl transition-colors"
      >
        Back to Home
      </a>
      <a
        href="/tags"
        class="px-5 py-2.5 bg-gray-100 hover:bg-gray-200 dark:bg-gray-800 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300 text-sm font-medium rounded-xl transition-colors"
      >
        Browse Tags
      </a>
    </div>
  </div>
</Layout>
