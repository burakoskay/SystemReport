---
import Layout from '../../layouts/Layout.astro';
import { TERMS, ADDRESS_LINES } from '../../i18n/policy-strings';
import { LOCALE_LIST, HREFLANG, localeToSlug, type Locale } from '../../i18n/tool-strings';

export async function getStaticPaths() {
  return LOCALE_LIST
    .filter((l) => l !== 'en')
    .map((l) => ({ params: { locale: localeToSlug(l) }, props: { locale: l } }));
}

interface Props { locale: Locale; }
const { locale } = Astro.props;
const s = TERMS[locale];
const siteBase = 'https://www.systemreport.net';
const slug = localeToSlug(locale);

const hreflangAlternates = [
  { hreflang: 'en', href: `${siteBase}/terms` },
  { hreflang: 'x-default', href: `${siteBase}/terms` },
  ...LOCALE_LIST.filter(l => l !== 'en').map(l => ({
    hreflang: HREFLANG[l],
    href: `${siteBase}/${localeToSlug(l)}/terms`,
  })),
];

const addressHtml = ADDRESS_LINES.join('<br />');
const bodyHtml = s.bodyHtml
  .replace(/class="lead"/g, 'class="text-xl text-gray-500 dark:text-gray-400 leading-relaxed"')
  .replace(/__ADDRESS__/g, addressHtml)
  .replace(/__CONTACT__/g, `/${slug}/contact`)
  .replace(/__PRIVACY__/g, `/${slug}/privacy`);
---

<Layout
  title={s.metaTitle}
  description={s.metaDescription}
  url={`${siteBase}/${slug}/terms`}
  lang={HREFLANG[locale]}
  hreflangAlternates={hreflangAlternates}
>
  <article class="max-w-3xl mx-auto">
    <h1 class="font-serif text-4xl font-bold text-gray-900 dark:text-gray-100 mb-6">
      {s.h1}
    </h1>
    {s.lastUpdated && (
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-8">{s.lastUpdated}</p>
    )}
    <div class="prose prose-lg prose-gray dark:prose-invert max-w-none prose-headings:font-serif prose-a:text-blue-600 dark:prose-a:text-blue-400" set:html={bodyHtml} />
  </article>
</Layout>
