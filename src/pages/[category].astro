---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, NAV_CATEGORIES, getArticleCategory } from '../lib/categories';

export async function getStaticPaths() {
  return NAV_CATEGORIES.map(({ slug }) => ({ params: { category: slug } }));
}

const { category } = Astro.params;
const catInfo = CATEGORIES[category];

const allPosts = await getCollection('posts');
const sorted = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const posts = sorted.filter(p => getArticleCategory(p.data.tags ?? []) === category);

const featuredPost = posts[0];
const sidebarPosts = posts.slice(1, 5);
const gridPosts    = posts.slice(5);

function formatDate(date: Date) {
  const d = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
  const t = date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true, timeZone: 'UTC' });
  return `${d} · ${t} UTC`;
}
---

<Layout title={`${catInfo.label} — System Report`} description={`Latest ${catInfo.label} news and analysis from System Report.`}>

  <div class="section-label mt-8 mb-10">{catInfo.label}</div>

  {posts.length === 0 && (
    <div class="py-20 text-center">
      <h2 class="text-xl font-serif font-semibold text-gray-900 dark:text-gray-100 mb-2">No articles yet</h2>
      <p class="text-gray-500 dark:text-gray-400">Check back soon — new content is on the way.</p>
    </div>
  )}

  {featuredPost && (
    <section class="pb-12 border-b border-gray-200 dark:border-gray-800">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-0">

        <!-- Main featured article -->
        <a href={`/posts/${featuredPost.id}`} class="lg:col-span-2 lg:pr-8 group block">
          {featuredPost.data.hero_image && (
            <div class="overflow-hidden rounded-xl aspect-video bg-gray-100 dark:bg-gray-800">
              <img
                src={featuredPost.data.hero_image}
                alt={featuredPost.data.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="eager"
                fetchpriority="high"
              />
            </div>
          )}
          <div class="pt-5">
            <span class="text-[0.65rem] font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">
              {catInfo.label}
            </span>
            <h2 class="mt-2 font-serif text-2xl sm:text-3xl lg:text-4xl font-bold leading-tight text-gray-900 dark:text-gray-50 group-hover:text-black dark:group-hover:text-white transition-colors">
              {featuredPost.data.title}
            </h2>
            {featuredPost.data.description && (
              <p class="mt-3 text-base text-gray-500 dark:text-gray-400 leading-relaxed line-clamp-2 max-w-2xl">
                {featuredPost.data.description}
              </p>
            )}
            <time class="mt-3 block text-sm text-gray-500 dark:text-gray-400">
              {formatDate(featuredPost.data.date)}
            </time>
          </div>
        </a>

        <!-- Sidebar: 4 secondary articles -->
        {sidebarPosts.length > 0 && (
          <div class="flex flex-col border-t lg:border-t-0 lg:border-l border-gray-200 dark:border-gray-800 pt-8 lg:pt-0 lg:pl-8 mt-8 lg:mt-0">
            {sidebarPosts.map((post, i) => (
              <a
                href={`/posts/${post.id}`}
                class:list={['group flex gap-4 py-5', i > 0 ? 'border-t border-gray-100 dark:border-gray-800' : '']}
              >
                <div class="flex-1 min-w-0">
                  <span class="text-[0.6rem] font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">
                    {catInfo.label}
                  </span>
                  <h3 class="mt-1 font-serif text-[0.95rem] font-semibold leading-snug text-gray-900 dark:text-gray-100 group-hover:text-black dark:group-hover:text-white transition-colors line-clamp-3">
                    {post.data.title}
                  </h3>
                  <time class="mt-2 block text-xs text-gray-500 dark:text-gray-400">
                    {formatDate(post.data.date)}
                  </time>
                </div>
                {post.data.hero_image && (
                  <div class="w-24 h-24 flex-shrink-0 overflow-hidden rounded-lg bg-gray-100 dark:bg-gray-800">
                    <img
                      src={post.data.hero_image}
                      alt={post.data.title}
                      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                )}
              </a>
            ))}
          </div>
        )}

      </div>
    </section>
  )}

  {gridPosts.length > 0 && (
    <section class="mt-12">
      <div class="section-label mb-8">More {catInfo.label}</div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {gridPosts.map((post, i) => (
          <div class:list={[`stagger-${Math.min(i + 1, 12)}`]}>
            <ArticleCard
              title={post.data.title}
              slug={post.id}
              date={post.data.date}
              heroImage={post.data.hero_image}
              tags={post.data.tags}
              description={post.data.description}
              body={post.body || ''}
            />
          </div>
        ))}
      </div>
    </section>
  )}

</Layout>
