---
import Layout from '../../layouts/Layout.astro';
import { TOOLS } from '../../data/tools';

const title = 'Free Privacy & Developer Tools — System Report';
const description =
  'A growing collection of fast, private, browser-based tools. No uploads, no tracking, no accounts. ' +
  'Built for readers who care about how their data is handled.';

const collectionSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'System Report Tools',
  description,
  url: 'https://www.systemreport.net/tools/',
  hasPart: TOOLS.filter((t) => t.status === 'live').map((t) => ({
    '@type': 'SoftwareApplication',
    name: t.title,
    description: t.description,
    url: `https://www.systemreport.net/tools/${t.slug}/`,
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any (runs in web browser)',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  })),
});
---

<Layout title={title} description={description} schema={collectionSchema}>
  <div class="max-w-5xl mx-auto">
    <!-- Hero -->
    <header class="mb-12 text-center">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gray-500 dark:text-gray-400 mb-3">
        Tools
      </p>
      <h1 class="font-serif text-4xl sm:text-5xl font-bold text-gray-900 dark:text-gray-100 mb-4 tracking-tight">
        Private tools that run in your browser
      </h1>
      <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed">
        A growing collection of utilities built with one rule: your data never leaves your device. No uploads, no accounts, no tracking.
      </p>
    </header>

    <!-- Trust strip -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-12">
      <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800">
        <svg class="w-5 h-5 text-green-600 dark:text-green-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span class="text-sm text-gray-700 dark:text-gray-300">100% client-side</span>
      </div>
      <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800">
        <svg class="w-5 h-5 text-green-600 dark:text-green-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
        </svg>
        <span class="text-sm text-gray-700 dark:text-gray-300">No uploads, ever</span>
      </div>
      <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800">
        <svg class="w-5 h-5 text-green-600 dark:text-green-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z"/>
        </svg>
        <span class="text-sm text-gray-700 dark:text-gray-300">Free, no sign-up</span>
      </div>
    </div>

    <!-- Tools grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {TOOLS.map((tool) => (
        <a
          href={tool.status === 'live' ? `/tools/${tool.slug}/` : '#'}
          class:list={[
            'group block p-6 rounded-2xl border transition-all',
            tool.status === 'live'
              ? 'bg-white dark:bg-gray-950 border-gray-200 dark:border-gray-800 hover:border-gray-400 dark:hover:border-gray-600 hover:shadow-lg dark:hover:shadow-none hover:-translate-y-0.5'
              : 'bg-gray-50 dark:bg-gray-900/50 border-gray-200 dark:border-gray-800 opacity-60 cursor-not-allowed'
          ]}
          aria-disabled={tool.status !== 'live'}
        >
          <div class="flex items-start justify-between mb-4">
            <div class="w-11 h-11 rounded-xl bg-gray-100 dark:bg-gray-800 flex items-center justify-center group-hover:bg-gray-900 group-hover:text-white dark:group-hover:bg-gray-100 dark:group-hover:text-gray-900 transition-colors">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={tool.iconPath}/>
              </svg>
            </div>
            <span class:list={[
              'text-[10px] font-semibold tracking-wider uppercase px-2 py-1 rounded',
              tool.status === 'live'
                ? 'bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400'
                : 'bg-gray-200 text-gray-600 dark:bg-gray-800 dark:text-gray-400'
            ]}>
              {tool.status === 'live' ? tool.category : 'Soon'}
            </span>
          </div>
          <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">
            {tool.title}
          </h2>
          <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">
            {tool.tagline}
          </p>
        </a>
      ))}
    </div>

    <!-- What's coming -->
    <section class="mt-16 pt-12 border-t border-gray-200 dark:border-gray-800">
      <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-gray-100 mb-4">What's coming</h2>
      <p class="text-gray-600 dark:text-gray-300 leading-relaxed max-w-2xl">
        We're building out this section with tools where "runs in your browser, never touches a server" is a real feature — not a marketing claim. Next up: an LLM memory / VRAM calculator with first-class support for Apple Silicon's unified memory, a model-accurate token counter, and a regex playground with categorised templates. Have a tool you wish existed? <a href="/about" class="text-blue-600 dark:text-blue-400 hover:underline">Let us know</a>.
      </p>
    </section>
  </div>
</Layout>
