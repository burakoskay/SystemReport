---
import Layout from '../../layouts/Layout.astro';

const title = 'EXIF Remover — Strip Metadata from Photos in Your Browser (Free)';
const description =
  'Free EXIF metadata remover. Strip GPS coordinates, camera model, serial number, and timestamps from JPEG, PNG, and WebP images. 100% client-side — your photos never upload anywhere.';
const canonical = 'https://www.systemreport.net/tools/exif-stripper/';

// Structured data: SoftwareApplication describes the tool, HowTo gives
// the step-by-step Google/Bing show in rich results, FAQPage feeds
// People-Also-Ask and LLM retrieval.
const schema = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'System Report EXIF Remover',
    applicationCategory: 'MultimediaApplication',
    operatingSystem: 'Any (runs in web browser)',
    url: canonical,
    description,
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    aggregateRating: undefined, // intentionally omitted — ratings must be real
    featureList: [
      'Removes GPS coordinates (latitude, longitude, altitude)',
      'Removes camera make, model, and serial number',
      'Removes original and modified timestamps',
      'Removes software tags, lens information, and owner names',
      'Supports JPEG, PNG, and WebP',
      'Batch processing — handles many files at once',
      'Runs entirely in the browser — no server uploads',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How to remove EXIF metadata from a photo',
    description: 'Strip GPS and other metadata from an image file using a browser-based tool.',
    totalTime: 'PT30S',
    step: [
      { '@type': 'HowToStep', position: 1, name: 'Select your image', text: 'Drag and drop one or more image files onto the tool, or click to browse.' },
      { '@type': 'HowToStep', position: 2, name: 'Review what will be removed', text: 'The tool parses your image locally and lists the metadata it found — GPS, camera details, timestamps.' },
      { '@type': 'HowToStep', position: 3, name: 'Download the clean image', text: 'Click download. The cleaned file is generated in your browser with all personal metadata stripped.' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is EXIF metadata?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'EXIF (Exchangeable Image File Format) is data that cameras and phones embed inside image files. It includes GPS coordinates, camera make and model, lens information, shutter speed, ISO, date and time of capture, and sometimes device owner details or serial numbers.',
        },
      },
      {
        '@type': 'Question',
        name: 'Why should I remove EXIF data before sharing photos?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'EXIF data can reveal your home address (GPS tags), your daily routine (timestamps), the exact device you use, and sometimes your name. Stripping it before posting photos online prevents strangers from inferring where and when a photo was taken.',
        },
      },
      {
        '@type': 'Question',
        name: 'Does this tool upload my photos anywhere?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'No. Everything runs in your browser using JavaScript and the File API. You can verify this by opening your browser\'s network inspector — no network requests are made when you process a file. The tool works offline once the page has loaded.',
        },
      },
      {
        '@type': 'Question',
        name: 'What image formats are supported?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'JPEG (.jpg, .jpeg), PNG (.png), and WebP (.webp). HEIC and TIFF are not yet supported — the tool will warn you if you upload one.',
        },
      },
      {
        '@type': 'Question',
        name: 'Does removing EXIF reduce image quality?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'No. This tool strips only the metadata segments of the file — the actual pixel data is left untouched. The cleaned image is byte-for-byte identical to the original in terms of visual content.',
        },
      },
      {
        '@type': 'Question',
        name: 'Is the color profile preserved?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. The embedded ICC color profile is preserved because removing it can shift how colors render. Only personal metadata (GPS, camera, timestamps, text comments) is stripped.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can I process many photos at once?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. Drop multiple files at once and the tool will clean each one in parallel. There is no file count or total size limit beyond what your browser can hold in memory.',
        },
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.systemreport.net/' },
      { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://www.systemreport.net/tools/' },
      { '@type': 'ListItem', position: 3, name: 'EXIF Remover', item: canonical },
    ],
  },
]);
---

<Layout title={title} description={description} schema={schema}>
  <div class="max-w-4xl mx-auto">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm text-gray-500 dark:text-gray-400" aria-label="Breadcrumb">
      <a href="/" class="hover:text-gray-900 dark:hover:text-gray-100">Home</a>
      <span class="mx-2">/</span>
      <a href="/tools/" class="hover:text-gray-900 dark:hover:text-gray-100">Tools</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900 dark:text-gray-100">EXIF Remover</span>
    </nav>

    <!-- Hero -->
    <header class="mb-8">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gray-500 dark:text-gray-400 mb-3">
        Privacy Tool
      </p>
      <h1 class="font-serif text-4xl sm:text-5xl font-bold text-gray-900 dark:text-gray-100 mb-4 tracking-tight">
        Remove EXIF Metadata from Photos
      </h1>
      <p class="text-lg text-gray-500 dark:text-gray-400 leading-relaxed max-w-3xl">
        Strip GPS coordinates, camera details, and timestamps from JPEG, PNG, and WebP images. Everything happens inside this page — <strong class="text-gray-900 dark:text-gray-100 font-semibold">your files never leave your browser</strong>.
      </p>
    </header>

    <!-- Privacy banner -->
    <div class="mb-6 flex items-start gap-3 p-4 rounded-xl bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-900/40">
      <svg class="w-5 h-5 text-green-600 dark:text-green-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div class="text-sm text-green-900 dark:text-green-200 leading-relaxed">
        <strong class="font-semibold">No uploads. No tracking. No accounts.</strong>
        Open your browser's network inspector and drop a file — you'll see zero requests. This page works offline once loaded.
      </div>
    </div>

    <!-- Tool -->
    <section id="tool" class="mb-12">
      <div
        id="dropzone"
        class="relative border-2 border-dashed border-gray-300 dark:border-gray-700 rounded-2xl p-10 sm:p-14 text-center cursor-pointer hover:border-gray-400 dark:hover:border-gray-500 hover:bg-gray-50 dark:hover:bg-gray-900/50 transition-colors"
        tabindex="0"
        role="button"
        aria-label="Drop image files here or click to browse"
      >
        <input id="file-input" type="file" multiple accept="image/jpeg,image/png,image/webp,.jpg,.jpeg,.png,.webp" class="hidden"/>
        <svg class="w-12 h-12 mx-auto text-gray-400 dark:text-gray-600 mb-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 8.25H7.5a2.25 2.25 0 00-2.25 2.25v9a2.25 2.25 0 002.25 2.25h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25H15M9 12l3 3m0 0l3-3m-3 3V2.25"/>
        </svg>
        <p class="text-base font-medium text-gray-900 dark:text-gray-100 mb-1">
          Drop photos here
        </p>
        <p class="text-sm text-gray-500 dark:text-gray-400">
          or <span class="text-blue-600 dark:text-blue-400 underline underline-offset-2">browse your device</span>
