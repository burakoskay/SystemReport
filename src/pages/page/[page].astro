---
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Pagination from '../../components/Pagination.astro';
import AdUnit from '../../components/AdUnit.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const ARTICLES_PER_PAGE = 12;
  const allPosts = await getCollection('posts');
  const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  const totalPages = Math.max(1, Math.ceil(sortedPosts.length / ARTICLES_PER_PAGE));

  // Generate pages 2, 3, 4... (page 1 is the homepage)
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => ({
    params: { page: String(i + 2) },
    props: {
      page: i + 2,
      posts: sortedPosts.slice((i + 1) * ARTICLES_PER_PAGE, (i + 2) * ARTICLES_PER_PAGE),
      totalPages,
    },
  }));
}

const { page, posts, totalPages } = Astro.props;
---

<Layout title={`Page ${page} — System Report`} description={`Tech news, page ${page} of ${totalPages}.`}>
  <section class="mb-8 pt-8">
    <nav class="text-sm text-gray-500 dark:text-gray-400 mb-6">
      <a href="/" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Home</a>
      <span class="mx-2 text-gray-300 dark:text-gray-600">/</span>
      <span>Page {page}</span>
    </nav>
    <div class="section-label">All Articles — Page {page}</div>
  </section>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {posts.map((post: any, i: number) => (
      <>
        <div class:list={[`stagger-${i + 1}`]}>
          <ArticleCard
            title={post.data.title}
            slug={post.id}
            date={post.data.date}
            heroImage={post.data.hero_image}
            tags={post.data.tags}
            description={post.data.description}
            body={post.body || ''}
          />
        </div>
        {(i + 1) % 4 === 0 && i < posts.length - 1 && (
          <div class="col-span-full">
            <AdUnit format="horizontal" />
          </div>
        )}
      </>
    ))}
  </div>

  <Pagination currentPage={page} totalPages={totalPages} />
</Layout>
