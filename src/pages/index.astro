---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Pagination from '../components/Pagination.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import AdUnit from '../components/AdUnit.astro';
import { getCollection } from 'astro:content';

const ARTICLES_PER_PAGE = 12;

const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const totalPages = Math.max(1, Math.ceil(sortedPosts.length / ARTICLES_PER_PAGE));
const currentPage = 1;
const paginatedPosts = sortedPosts.slice(0, ARTICLES_PER_PAGE);
---

<Layout title="System Report — Tech News & Analysis">
  <!-- Hero -->
  <section class="mb-12 pt-4 md:pt-8">
    <div class="max-w-3xl">
      <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight text-gray-900 dark:text-gray-50 leading-[1.1]">
        The latest signals
        <br />
        <span class="bg-gradient-to-r from-blue-600 to-indigo-600 dark:from-blue-400 dark:to-indigo-400 bg-clip-text text-transparent">
          in tech
        </span>
      </h1>
      <p class="mt-5 text-lg text-gray-500 dark:text-gray-400 leading-relaxed max-w-xl">
        Comprehensive analysis from across the tech landscape. Expert-level coverage, updated throughout the day.
      </p>
      {sortedPosts.length > 0 && (
        <p class="mt-3 text-sm text-gray-400 dark:text-gray-500">
          {sortedPosts.length} articles and counting
        </p>
      )}
    </div>
  </section>

  <!-- Article Grid -->
  {paginatedPosts.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {paginatedPosts.map((post, i) => (
        <>
          <div class:list={[`stagger-${i + 1}`]}>
            <ArticleCard
              title={post.data.title}
              slug={post.id}
              date={post.data.date}
              heroImage={post.data.hero_image}
              tags={post.data.tags}
              description={post.data.description}
              body={post.body || ''}
            />
          </div>
          {/* Ad unit after every 4th card */}
          {(i + 1) % 4 === 0 && i < paginatedPosts.length - 1 && (
            <div class="col-span-full">
              <AdUnit format="horizontal" />
            </div>
          )}
        </>
      ))}
    </div>
  ) : (
    <div class="py-20 text-center">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gray-100 dark:bg-gray-800 mb-4">
        <svg class="w-8 h-8 text-gray-400 dark:text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 0 1-2.25 2.25M16.5 7.5V18a2.25 2.25 0 0 0 2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 0 0 2.25 2.25h13.5M6 7.5h3v3H6v-3Z" />
        </svg>
      </div>
      <h2 class="text-xl font-serif font-semibold text-gray-900 dark:text-gray-100 mb-2">No articles yet</h2>
      <p class="text-gray-500 dark:text-gray-400">New articles are on the way. Check back soon.</p>
    </div>
  )}

  <!-- Pagination -->
  <Pagination currentPage={currentPage} totalPages={totalPages} />

  <!-- Newsletter -->
  <div class="mt-16">
    <NewsletterSignup />
  </div>
</Layout>
