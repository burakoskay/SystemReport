---
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { AUTHOR_LIST, getAuthor } from '../../lib/authors.mjs';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return AUTHOR_LIST.map((a) => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const author = getAuthor(slug);

const allPosts = await getCollection('posts');
const posts = allPosts
  .filter(p => p.data.author === slug)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const siteBase = (Astro.site || 'https://www.systemreport.net').toString().replace(/\/$/, '');

// Person schema — this is the authoritative E-E-A-T lift. Every article
// references this @id as the author, so the graph connects cleanly.
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${siteBase}/authors/${author.slug}#person`,
  "name": author.name,
  "jobTitle": author.title,
  "description": author.bio,
  "url": `${siteBase}/authors/${author.slug}`,
  "image": `${siteBase}${author.avatar}`,
  "worksFor": {
    "@type": "Organization",
    "name": "System Report",
    "url": siteBase,
  },
  "knowsAbout": author.tagHints,
};
---

<Layout
  title={`${author.name} — ${author.title} — System Report`}
  description={author.bio}
  url={`${siteBase}/authors/${author.slug}`}
  schema={JSON.stringify(personSchema)}
>
  <div class="max-w-4xl mx-auto">
    <header class="mt-8 mb-10 flex flex-col sm:flex-row gap-6 items-start">
      <img src={author.avatar} alt={author.name} width="160" height="160" loading="eager" class="w-32 h-32 sm:w-40 sm:h-40 rounded-full object-cover bg-gray-100 dark:bg-gray-800" />
      <div class="flex-1 min-w-0">
        <div class="section-label mb-2">{author.beat}</div>
        <h1 class="font-serif text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-50">{author.name}</h1>
        <div class="mt-1 text-sm text-gray-500 dark:text-gray-400">{author.title} · {author.location}</div>
        <p class="mt-4 text-gray-700 dark:text-gray-300 leading-relaxed max-w-2xl">{author.bio}</p>
      </div>
    </header>

    <section class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-800">
      <div class="section-label mb-6">Latest by {author.name.split(' ')[0]}</div>
      {posts.length === 0 ? (
        <p class="text-gray-500 dark:text-gray-400 py-8">No articles published yet.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-5">
          {posts.map((post) => (
            <div class="h-full">
              <ArticleCard
                title={post.data.title}
                slug={post.id}
                date={post.data.date}
                heroImage={post.data.hero_image}
                tags={post.data.tags}
                description={post.data.description}
                body={post.body || ''}
              />
            </div>
          ))}
        </div>
      )}
    </section>
  </div>
</Layout>
