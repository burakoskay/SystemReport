---
import Layout from '../../layouts/Layout.astro';
import { AUTHOR_LIST } from '../../lib/authors.mjs';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const countsBySlug = new Map();
for (const p of posts) {
  const a = p.data.author;
  if (!a) continue;
  countsBySlug.set(a, (countsBySlug.get(a) || 0) + 1);
}
---

<Layout title="The Team — System Report" description="Meet the reporters covering AI, hardware, policy, and the rest of tech for System Report.">
  <div class="max-w-4xl mx-auto">
    <header class="mt-8 mb-10">
      <div class="section-label mb-4">The Team</div>
      <h1 class="font-serif text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-50">Reporters covering the beat</h1>
      <p class="mt-3 text-gray-500 dark:text-gray-400 max-w-2xl">Our reporters cover AI, hardware, policy, consumer tech, enterprise, and internet culture. Each brings a different angle.</p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {AUTHOR_LIST.map((a) => (
        <a href={`/authors/${a.slug}`} class="group flex gap-4 p-5 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-gray-400 dark:hover:border-gray-600 transition-colors">
          <img src={a.avatar} alt={a.name} width="80" height="80" loading="lazy" class="w-20 h-20 rounded-full object-cover bg-gray-100 dark:bg-gray-800 flex-shrink-0" />
          <div class="min-w-0">
            <div class="font-serif text-lg font-semibold text-gray-900 dark:text-gray-100 group-hover:text-black dark:group-hover:text-white">{a.name}</div>
            <div class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400 mt-0.5">{a.title}</div>
            <p class="mt-2 text-sm text-gray-600 dark:text-gray-400 line-clamp-3">{a.bio}</p>
            <div class="mt-2 text-xs text-gray-500 dark:text-gray-400">
              {countsBySlug.get(a.slug) || 0} articles · {a.location}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
