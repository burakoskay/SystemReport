---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import TagPill from '../../components/TagPill.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import AdUnit from '../../components/AdUnit.astro';
import { getArticleCategory, CATEGORIES } from '../../lib/categories';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Calculate reading time
const words = (post.body || '').split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(words / 200));

// Get prev/next posts
const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const currentIndex = sortedPosts.findIndex((p) => p.id === post.id);
const prevPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
const nextPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedTime = post.data.date.toLocaleTimeString('en-US', {
  hour: 'numeric',
  minute: '2-digit',
  hour12: true,
  timeZone: 'UTC',
  timeZoneName: 'short',
});
const formattedModified = post.data.modified_date
  ? `${post.data.modified_date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })} · ${post.data.modified_date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true, timeZone: 'UTC', timeZoneName: 'short' })}`
  : null;

const articleUrl = `https://www.systemreport.net/posts/${post.id}`;

// Calculate word count for schema
const wordCount = (post.body || '').split(/\s+/).filter(Boolean).length;

const siteBase = (Astro.site || 'https://www.systemreport.net').toString().replace(/\/$/, '');

// Find translated versions of this post and emit hreflang alternates.
const translations = await getCollection('posts-i18n').catch(() => []);
const myTranslations = translations.filter(t => t.data.canonical_slug === post.id);
const hreflangAlternates = myTranslations.length > 0 ? [
  { hreflang: 'en', href: `${siteBase}/posts/${post.id}` },
  { hreflang: 'x-default', href: `${siteBase}/posts/${post.id}` },
  ...myTranslations.map(t => ({
    hreflang: t.data.locale!,
    href: `${siteBase}/${t.data.locale}/posts/${post.id}`,
  })),
] : [];

// Build fully-qualified hero image URL
const heroImageUrl = post.data.hero_image
  ? (post.data.hero_image.startsWith('http')
      ? post.data.hero_image
      : `${siteBase}${post.data.hero_image}`)
  : undefined;

// Parse image dimensions from Pexels-style URL params (?w=1260&h=750)
let heroWidth = 1260;
let heroHeight = 750;
if (heroImageUrl) {
  try {
    const u = new URL(heroImageUrl);
    const w = parseInt(u.searchParams.get('w') || '0');
    const h = parseInt(u.searchParams.get('h') || '0');
    if (w) heroWidth = w;
    if (h) heroHeight = h;
  } catch (_) { /* use defaults */ }
}

// Determine article section/category from tags
const articleCategorySlug = getArticleCategory(post.data.tags || []);
const articleSection = CATEGORIES[articleCategorySlug]?.label || 'Tech';

// Publisher logo must be PNG/WebP/JPEG — place a 600×60 PNG at public/logo.png
const publisherLogoUrl = `${siteBase}/logo.png`;

const articleSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "NewsArticle",
      "@id": `${articleUrl}#article`,
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": articleUrl
      },
      "headline": post.data.title,
      "description": post.data.description || post.data.title,
      "articleSection": articleSection,
      "isAccessibleForFree": true,
      ...(heroImageUrl ? {
        "image": [{
          "@type": "ImageObject",
          "url": heroImageUrl,
          "width": heroWidth,
          "height": heroHeight,
        }]
      } : {}),
      "datePublished": post.data.date.toISOString(),
      "dateModified": (post.data.modified_date || post.data.date).toISOString(),
      "wordCount": wordCount,
      "inLanguage": "en-US",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".prose"]
      },
      ...(post.data.audio_path ? {
        "audio": {
          "@type": "AudioObject",
          "contentUrl": `${siteBase}${post.data.audio_path}`,
          "encodingFormat": "audio/wav",
          "transcript": articleUrl,
        }
      } : {}),
      "author": [{
        "@type": "Person",
        "name": "System Report Staff",
        "url": `${siteBase}/about`
      }],
      "publisher": {
        "@type": "Organization",
        "@id": `${siteBase}/#organization`,
        "name": "System Report",
        "url": siteBase,
        "logo": {
          "@type": "ImageObject",
          "url": publisherLogoUrl,
          "width": 600,
          "height": 60,
        }
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": siteBase
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": articleSection,
          "item": `${siteBase}/${articleCategorySlug}`
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": post.data.title
        }
      ]
    }
  ]
};
---

<Layout
  title={`${post.data.title} — System Report`}
  description={post.data.description || post.data.title}
  image={post.data.hero_image}
  imageWidth={heroWidth}
  imageHeight={heroHeight}
  url={articleUrl}
  type="article"
  schema={JSON.stringify(articleSchema)}
  publishDate={post.data.date}
  tags={post.data.tags || []}
  section={articleSection}
  hreflangAlternates={hreflangAlternates}
  ampUrl={`${siteBase}/stories/${post.id}`}
>
  <article class="max-w-3xl mx-auto">
    <!-- Header -->
    <header class="mb-8">
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {post.data.tags.map((tag: string) => (
            <TagPill tag={tag} size="md" />
          ))}
        </div>
      )}

      <h1 class="font-serif text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-gray-900 dark:text-gray-50 leading-tight">
        {post.data.title}
      </h1>

      <div class="flex flex-wrap items-center gap-4 mt-5 text-sm text-gray-500 dark:text-gray-400">
        <time datetime={post.data.date.toISOString()} class="flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
          </svg>
          {formattedDate} · {formattedTime}
        </time>
        {post.data.modified_date && post.data.modified_date.valueOf() !== post.data.date.valueOf() && (
          <>
            <span class="w-1 h-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
            <span class="flex items-center gap-1.5 text-amber-600 dark:text-amber-400">
              Updated {formattedModified}
            </span>
          </>
        )}
        <span class="w-1 h-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          {readingTime} min read
        </span>
        {post.data.sources_count && (
          <>
            <span class="w-1 h-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
              </svg>
              {post.data.sources_count} sources
            </span>
          </>
        )}
      </div>
    </header>

    <!-- Hero Image -->
    {post.data.hero_image && (
      <div class="mb-10 -mx-4 sm:mx-0">
        <img
          class="w-full aspect-video object-cover rounded-none sm:rounded-2xl"
          src={post.data.hero_image}
          alt={post.data.visual_keyword || post.data.title}
          loading="eager"
        />
        {post.data.hero_image_credit_name && (
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-2 px-4 sm:px-0 text-right">
            {post.data.hero_image_credit_name.includes('Flux Schnell') ? null : (
              <>Photo by <a href={post.data.hero_image_credit_url} target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-600 dark:hover:text-gray-300">{post.data.hero_image_credit_name}</a> on <a href="https://www.pexels.com" target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-600 dark:hover:text-gray-300">Pexels</a></>
            )}
          </p>
        )}
      </div>
    )}

    <!-- Audio narration (when available) -->
    {post.data.audio_path && (
      <div class="sr-listen mb-10 mt-2 flex items-center gap-4 px-5 py-4 rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950">
        <button
          type="button"
          class="sr-listen-toggle shrink-0 w-12 h-12 rounded-full bg-gray-900 dark:bg-white text-white dark:text-black flex items-center justify-center hover:scale-105 active:scale-95 transition-transform"
          aria-label="Play narration"
        >
          <svg class="sr-listen-play w-5 h-5 ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
          <svg class="sr-listen-pause w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 5h4v14H6zM14 5h4v14h-4z" /></svg>
        </button>
        <div class="flex-1 min-w-0">
          <div class="flex items-baseline justify-between gap-3 mb-1.5">
            <span class="text-xs uppercase tracking-[0.18em] text-gray-500 dark:text-gray-400 font-medium">Listen to this article</span>
            <span class="sr-listen-time text-xs font-mono text-gray-500 dark:text-gray-400 tabular-nums">0:00 / --:--</span>
          </div>
          <div class="sr-listen-track relative h-1.5 rounded-full bg-gray-200 dark:bg-gray-800 cursor-pointer overflow-hidden">
            <div class="sr-listen-progress absolute inset-y-0 left-0 w-0 bg-gray-900 dark:bg-white rounded-full"></div>
          </div>
        </div>
        <audio class="sr-listen-audio hidden" preload="metadata" src={post.data.audio_path}></audio>
      </div>
    )}

    <script is:inline>
      (function () {
        document.querySelectorAll('.sr-listen').forEach((root) => {
          const audio = root.querySelector('.sr-listen-audio');
          const btn = root.querySelector('.sr-listen-toggle');
          const playIcon = root.querySelector('.sr-listen-play');
          const pauseIcon = root.querySelector('.sr-listen-pause');
          const track = root.querySelector('.sr-listen-track');
          const progress = root.querySelector('.sr-listen-progress');
          const timeEl = root.querySelector('.sr-listen-time');
          if (!audio || !btn) return;

          const fmt = (s) => {
            if (!isFinite(s) || s < 0) return '--:--';
            const m = Math.floor(s / 60);
            const r = Math.floor(s % 60);
            return m + ':' + (r < 10 ? '0' : '') + r;
          };
          const render = () => {
            const d = audio.duration || 0;
            const t = audio.currentTime || 0;
            progress.style.width = d ? (t / d) * 100 + '%' : '0%';
            timeEl.textContent = fmt(t) + ' / ' + fmt(d);
          };

          btn.addEventListener('click', () => {
            if (audio.paused) audio.play(); else audio.pause();
          });
          audio.addEventListener('play', () => {
            playIcon.classList.add('hidden');
            pauseIcon.classList.remove('hidden');
            btn.setAttribute('aria-label', 'Pause narration');
          });
          audio.addEventListener('pause', () => {
            playIcon.classList.remove('hidden');
            pauseIcon.classList.add('hidden');
            btn.setAttribute('aria-label', 'Play narration');
          });
          audio.addEventListener('timeupdate', render);
          audio.addEventListener('loadedmetadata', render);
          audio.addEventListener('ended', render);

          track.addEventListener('click', (e) => {
            const rect = track.getBoundingClientRect();
            const ratio = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
            if (audio.duration) audio.currentTime = ratio * audio.duration;
          });
        });
      })();
    </script>

    <!-- Ad before article -->
    <AdUnit format="horizontal" className="mb-8" />

    <!-- Article Body -->
    <div class="prose prose-lg prose-gray dark:prose-invert max-w-none
      prose-headings:font-serif prose-headings:tracking-tight
      prose-a:text-gray-900 dark:prose-a:text-gray-100 prose-a:underline prose-a:decoration-gray-300 dark:prose-a:decoration-gray-600 hover:prose-a:decoration-gray-900 dark:hover:prose-a:decoration-gray-100
      prose-img:rounded-xl
      prose-code:bg-gray-100 dark:prose-code:bg-gray-800 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:before:content-none prose-code:after:content-none
      prose-pre:bg-gray-900 dark:prose-pre:bg-gray-950 prose-pre:border prose-pre:border-gray-800
      prose-blockquote:border-gray-900 dark:prose-blockquote:border-gray-100 prose-blockquote:not-italic
    ">
      <Content />
    </div>

    <!-- Ad after article -->
    <AdUnit format="horizontal" className="mt-8" />

    <!-- Share + meta footer -->
    <div class="mt-10 pt-8 border-t border-gray-200 dark:border-gray-800 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <ShareButtons title={post.data.title} url={articleUrl} />
    </div>

    <!-- Prev/Next Navigation -->
    <nav class="mt-10 grid grid-cols-1 sm:grid-cols-2 gap-4" data-pagefind-ignore="all">
      {prevPost ? (
        <a href={`/posts/${prevPost.slug}`} class="group flex flex-col p-5 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-gray-400 dark:hover:border-gray-500 transition-colors">
          <span class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">← Previous</span>
          <span class="text-sm font-medium text-gray-900 dark:text-gray-100 group-hover:text-black dark:group-hover:text-white transition-colors line-clamp-2">
            {prevPost.data.title}
          </span>
        </a>
      ) : <div />}

      {nextPost && (
        <a href={`/posts/${nextPost.slug}`} class="group flex flex-col p-5 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-gray-400 dark:hover:border-gray-500 transition-colors text-right">
          <span class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Next →</span>
          <span class="text-sm font-medium text-gray-900 dark:text-gray-100 group-hover:text-black dark:group-hover:text-white transition-colors line-clamp-2">
            {nextPost.data.title}
          </span>
        </a>
      )}
    </nav>

    <!-- Newsletter -->
    <div class="mt-12">
      <NewsletterSignup compact />
    </div>

    <!-- Related Posts -->
    <RelatedPosts currentSlug={post.id} currentTags={post.data.tags || []} />
  </article>
</Layout>
